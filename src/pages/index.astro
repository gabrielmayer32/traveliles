---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import HeroVideo from '../components/HeroVideo.astro';
import VideoCard from '../components/VideoCard.astro';
import { iconSvg } from '../lib/icons';

const articles = (await getCollection('articles'))
	.filter((a) => a.data.published)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const videos = (await getCollection('videos'))
	.filter((v) => v.data.published)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const heroEntries = await getCollection('hero');
const heroEntry = heroEntries.find((h) => h.data.published);

// All videos go into the video section
const leadVideo = videos[0];
const gridVideos = videos.slice(1, 5);
// Feature article (horizontal, prominent) + 3-column grid below
const [featureArticle, ...gridArticles] = articles;
const latestArticles = gridArticles.slice(0, 3);
---

<BaseLayout locale="fr" alternateUrl="/en/">
	<!-- deploy -->
	<!-- Hero -->
	{heroEntry && (
		<section class="container-wide hero-section">
			<div class="hero-header">
				<span class="kicker">Le magazine vidéo de l'océan Indien</span>
			</div>
			<HeroVideo hero={heroEntry} />
		</section>
	)}

	<!-- Videos: lead + grid -->
	<section class="container-wide section videos-section">
		<div class="section-header">
			<div class="section-header-left">
				<span class="kicker">Vidéos</span>
				<h2 class="section-title">Dernières vidéos</h2>
			</div>
			<a class="section-cta" href="/videos">
				Toutes les vidéos <Fragment set:html={iconSvg('arrow-right', 16)} />
			</a>
		</div>

		{leadVideo && (
			<div class="videos-lead">
				<div class="videos-lead-card">
					<VideoCard video={leadVideo} size="lg" />
				</div>
				{gridVideos.length > 0 && (
					<div class="videos-lead-grid">
						{gridVideos.map((v) => <VideoCard video={v} />)}
					</div>
				)}
			</div>
		)}
	</section>

	<!-- Articles: feature lead + grid -->
	<section class="container-wide section articles-section">
		<div class="section-header">
			<div class="section-header-left">
				<span class="kicker">Articles</span>
				<h2 class="section-title">À lire</h2>
			</div>
			<a class="section-cta" href="/articles">
				Tous les articles <Fragment set:html={iconSvg('arrow-right', 16)} />
			</a>
		</div>
		{featureArticle && (
			<div class="articles-feature">
				<ArticleCard article={featureArticle} orientation="horizontal" size="lg" />
			</div>
		)}
		{latestArticles.length > 0 && (
			<div class="grid-3">
				{latestArticles.map((article) => <ArticleCard article={article} />)}
			</div>
		)}
	</section>
</BaseLayout>

<style>
	.hero-section {
		padding-top: var(--space-10);
	}

	.hero-header {
		margin-bottom: var(--space-5);
	}

	.section-header-left {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}

	.section-cta {
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		color: var(--navy);
		font-size: var(--text-sm);
		font-weight: var(--fw-semibold);
		letter-spacing: 0.06em;
		text-transform: uppercase;
		white-space: nowrap;
		flex-shrink: 0;
	}

	/* Videos — large lead left (58%), stacked column right (42%) */
	.videos-section {
		padding-bottom: var(--space-20);
	}

	.videos-lead {
		display: grid;
		grid-template-columns: minmax(0, 58fr) minmax(0, 42fr);
		gap: var(--space-8);
		align-items: start;
	}

	.videos-lead-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		gap: var(--space-6);
	}

	/* Articles section */
	.articles-section {
		padding-top: var(--space-20);
	}

	.articles-feature {
		margin-bottom: var(--space-16);
		padding-bottom: var(--space-16);
		border-bottom: 1px solid var(--border-subtle);
	}

	@media (max-width: 860px) {
		.videos-lead {
			grid-template-columns: 1fr;
		}

		.videos-lead-grid {
			grid-template-columns: 1fr 1fr;
		}
	}

	@media (max-width: 640px) {
		.hero-header {
			flex-direction: column;
			gap: var(--space-2);
		}

		.videos-lead-grid {
			grid-template-columns: 1fr;
		}

		.videos-lead-card :global(.video-card--lg .video-title) {
			font-size: var(--text-lg);
		}

}
</style>
