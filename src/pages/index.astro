---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import HeroVideo from '../components/HeroVideo.astro';
import PartnersBar from '../components/PartnersBar.astro';
import VideoCard from '../components/VideoCard.astro';
import { iconSvg } from '../lib/icons';

const articles = (await getCollection('articles'))
	.filter((a) => a.data.published)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const videos = (await getCollection('videos'))
	.filter((v) => v.data.published)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const heroEntries = await getCollection('hero');
const heroEntry = heroEntries.find((h) => h.data.published);

// All videos go into the video section
const leadVideo = videos[0];
const gridVideos = videos.slice(1, 3);
const leadArticle = articles[0];
const sideArticles = articles.slice(1, 3);
const carouselVideos = videos.slice(0, 6);
---

<BaseLayout locale="fr" alternateUrl="/en/">
	<!-- deploy -->
	<!-- Hero -->
	{heroEntry && (
		<section class="container-wide hero-section">
			<HeroVideo hero={heroEntry} />
		</section>
	)}

	<!-- Videos: lead + grid -->
	<section class="container-wide section videos-section">
		<div class="section-header">
			<div class="section-header-left">
				<h2 class="section-title">Dernières vidéos</h2>
			</div>
			<a class="section-cta" href="/videos">
				Toutes les vidéos <Fragment set:html={iconSvg('arrow-right', 16)} />
			</a>
		</div>

		{leadVideo && (
			<div class="videos-lead">
				<div class="videos-lead-card">
					<VideoCard video={leadVideo} size="lg" />
				</div>
				{gridVideos.length > 0 && (
					<div class="videos-lead-grid">
						{gridVideos.map((v) => <VideoCard video={v} size="sm" />)}
					</div>
				)}
			</div>
		)}
	</section>

	<!-- Articles: feature lead + grid -->
	<section class="container-wide section articles-section">
		<div class="section-header">
			<div class="section-header-left">
				<h2 class="section-title">Articles</h2>
			</div>
			<a class="section-cta" href="/articles">
				Tous les articles <Fragment set:html={iconSvg('arrow-right', 16)} />
			</a>
		</div>
		{leadArticle && (
			<div class="articles-lead">
				<div class="articles-lead-card">
					<ArticleCard article={leadArticle} size="lg" />
				</div>
				{sideArticles.length > 0 && (
					<div class="articles-lead-grid">
						{sideArticles.map((article) => <ArticleCard article={article} size="sm" />)}
					</div>
				)}
			</div>
		)}
	</section>

	<!-- Video carousel -->
	{carouselVideos.length > 0 && (
		<section class="container-wide section carousel-section">
			<div class="section-header">
				<div class="section-header-left">
					<h2 class="section-title">À voir aussi</h2>
				</div>
				<div class="carousel-arrows">
					<button class="carousel-arrow carousel-prev" type="button" aria-label="Précédent" data-dir="prev">
						<Fragment set:html={iconSvg('arrow-left', 20)} />
					</button>
					<button class="carousel-arrow carousel-next" type="button" aria-label="Suivant" data-dir="next">
						<Fragment set:html={iconSvg('arrow-right', 20)} />
					</button>
				</div>
			</div>
			<div class="carousel-track-wrapper">
				<div class="carousel-track">
					{carouselVideos.map((v) => (
						<div class="carousel-slide">
							<VideoCard video={v} />
						</div>
					))}
				</div>
			</div>
		</section>
	)}

	<PartnersBar />

<script>
function setupCarousel() {
	const wrapper = document.querySelector<HTMLElement>('.carousel-track-wrapper');
	const track = document.querySelector<HTMLElement>('.carousel-track');
	const prev = document.querySelector<HTMLButtonElement>('.carousel-prev');
	const next = document.querySelector<HTMLButtonElement>('.carousel-next');
	if (!wrapper || !track || !prev || !next) return;

	const slides = track.querySelectorAll<HTMLElement>('.carousel-slide');
	if (slides.length === 0) return;

	let index = 0;

	function visibleCount() {
		const w = window.innerWidth;
		if (w <= 560) return 1;
		if (w <= 860) return 2;
		return 3;
	}

	function maxIndex() {
		return Math.max(0, slides.length - visibleCount());
	}

	function update() {
		const slide = slides[0];
		const gap = parseFloat(getComputedStyle(track).gap) || 0;
		const offset = index * (slide.offsetWidth + gap);
		track.style.transform = `translateX(-${offset}px)`;
		prev.disabled = index === 0;
		next.disabled = index >= maxIndex();
	}

	prev.addEventListener('click', () => { if (index > 0) { index--; update(); } });
	next.addEventListener('click', () => { if (index < maxIndex()) { index++; update(); } });
	window.addEventListener('resize', () => { index = Math.min(index, maxIndex()); update(); });
	update();
}

document.addEventListener('astro:page-load', setupCarousel);
setupCarousel();
</script>
</BaseLayout>

<style>
	.hero-section {
		padding-top: var(--space-10);
	}

	.section-header-left {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}

	.section-cta {
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		color: var(--navy);
		font-size: var(--text-sm);
		font-weight: var(--fw-semibold);
		letter-spacing: 0.06em;
		text-transform: uppercase;
		white-space: nowrap;
		flex-shrink: 0;
	}

	/* Videos — large lead left (58%), stacked column right (42%) */
	.videos-section {
		padding-bottom: var(--space-10);
	}

	.videos-lead {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
		gap: var(--space-8);
		align-items: stretch;
	}

	.videos-lead-grid {
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		gap: var(--space-6);
	}

	/* Articles section */
	.articles-section {
		padding-top: var(--space-8);
		padding-bottom: var(--space-10);
	}

.articles-lead {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
		gap: var(--space-8);
		align-items: stretch;
	}

	.articles-lead-grid {
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		gap: var(--space-6);
	}

	.articles-lead-grid :global(.article-card--sm) {
		flex-direction: row;
		gap: var(--space-4);
		align-items: flex-start;
	}

	.articles-lead-grid :global(.article-card--sm .article-image) {
		width: 45%;
		flex-shrink: 0;
	}

	.articles-lead-grid :global(.article-card--sm .article-body) {
		flex: 1;
		min-width: 0;
	}

	@media (max-width: 860px) {
		.videos-lead,
		.articles-lead {
			grid-template-columns: 1fr;
		}

		.videos-lead-grid {
			grid-template-columns: 1fr 1fr;
		}

		.articles-lead-grid {
			flex-direction: row;
			gap: var(--space-8);
		}
	}

	@media (max-width: 640px) {
		.videos-lead-grid {
			grid-template-columns: 1fr;
		}

		.videos-lead-card :global(.video-card--lg .video-title) {
			font-size: var(--text-lg);
		}

		.articles-lead-grid {
			flex-direction: column;
		}
	}

	/* Carousel */
	.carousel-section {
		padding-top: var(--space-8);
		padding-bottom: var(--space-10);
	}

	.carousel-arrows {
		display: flex;
		gap: var(--space-2);
		flex-shrink: 0;
	}

	.carousel-arrow {
		display: grid;
		place-items: center;
		width: 44px;
		height: 44px;
		border: 1px solid var(--border-strong);
		border-radius: var(--radius-pill);
		background: var(--white);
		color: var(--ink);
		cursor: pointer;
		transition: all var(--dur-fast) var(--ease-out);
	}

	.carousel-arrow:hover:not(:disabled) {
		background: var(--navy);
		border-color: var(--navy);
		color: var(--white);
	}

	.carousel-arrow:disabled {
		opacity: 0.3;
		cursor: default;
	}

	.carousel-track-wrapper {
		overflow: hidden;
	}

	.carousel-track {
		display: flex;
		gap: var(--space-8);
		transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
	}

	.carousel-slide {
		flex: 0 0 calc((100% - var(--space-8) * 2) / 3);
		min-width: 0;
	}

	@media (max-width: 860px) {
		.carousel-slide {
			flex: 0 0 calc((100% - var(--space-8)) / 2);
		}
	}

	@media (max-width: 560px) {
		.carousel-slide {
			flex: 0 0 100%;
		}
	}
</style>
