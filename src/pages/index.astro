---
const comingSoon = import.meta.env.COMING_SOON === 'true';

import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import HeroVideo from '../components/HeroVideo.astro';
import VideoCard from '../components/VideoCard.astro';
import { iconSvg } from '../lib/icons';

const articles = (await getCollection('articles'))
	.filter((a) => a.data.published)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const videos = (await getCollection('videos'))
	.filter((v) => v.data.published)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const [heroVideo, ...restVideos] = videos;
// Lead video card + up to 4 secondary cards in the grid
const leadVideo = restVideos[0];
const gridVideos = restVideos.slice(1, 5);
// Feature article (horizontal, prominent) + 3-column grid below
const [featureArticle, ...gridArticles] = articles;
const latestArticles = gridArticles.slice(0, 3);
---

{comingSoon ? (
<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content="Travel-Îles arrive bientôt. Voyages, saveurs, cultures et adresses à Maurice et dans les îles de l'océan Indien." />
		<meta name="robots" content="noindex, nofollow" />
		<title>Bientôt disponible — Travel-Îles</title>
		<style>
			*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
			body {
				min-height: 100dvh;
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				background: #ffffff;
				font-family: system-ui, sans-serif;
				padding: 2rem;
				text-align: center;
			}
			.wordmark {
				font-size: clamp(1.5rem, 6vw, 3rem);
				font-weight: 700;
				letter-spacing: 0.25em;
				text-transform: uppercase;
				color: #141a1a;
				margin-bottom: 3rem;
			}
			.divider {
				width: 3rem;
				height: 2px;
				background: #2b3a8f;
				margin: 0 auto 2.5rem;
			}
			h1 {
				font-size: clamp(1rem, 3vw, 1.25rem);
				font-weight: 400;
				letter-spacing: 0.15em;
				text-transform: uppercase;
				color: #2b3a8f;
				margin-bottom: 1.25rem;
			}
			p { font-size: 1rem; line-height: 1.7; color: #444444; max-width: 36ch; margin: 0 auto; }
		</style>
	</head>
	<body>
		<div class="wordmark">Travel-Îles</div>
		<div class="divider"></div>
		<h1>Bientôt disponible</h1>
		<p>Le magazine des îles de l'océan Indien arrive bientôt. Voyages, saveurs, cultures et art de vivre.</p>
	</body>
</html>
) : (
<BaseLayout>
	<!-- Hero -->
	{heroVideo && (
		<section class="container-wide hero-section">
			<div class="hero-header">
				<span class="kicker">À la une · Vidéo</span>
				<span class="meta hero-tagline">Le magazine vidéo de l'océan Indien</span>
			</div>
			<HeroVideo video={heroVideo} />
		</section>
	)}

	<!-- Videos: lead + grid -->
	<section class="container-wide section videos-section">
		<div class="section-header">
			<div class="section-header-left">
				<span class="kicker">Vidéos</span>
				<h2 class="section-title">Dernières vidéos</h2>
			</div>
			<a class="section-cta" href="/videos">
				Toutes les vidéos <Fragment set:html={iconSvg('arrow-right', 16)} />
			</a>
		</div>

		{leadVideo && (
			<div class="videos-lead">
				<div class="videos-lead-card">
					<VideoCard video={leadVideo} size="lg" />
				</div>
				{gridVideos.length > 0 && (
					<div class="videos-lead-grid">
						{gridVideos.map((v) => <VideoCard video={v} />)}
					</div>
				)}
			</div>
		)}
	</section>

	<!-- Feature article — editorial horizontal banner -->
	{featureArticle && (
		<section class="feature-band">
			<div class="container-wide section feature-section">
				<div class="feature-label">
					<span class="kicker">En lecture</span>
				</div>
				<ArticleCard article={featureArticle} orientation="horizontal" size="lg" />
			</div>
		</section>
	)}

	<!-- Articles grid -->
	<section class="container-wide section articles-section">
		<div class="section-header">
			<div class="section-header-left">
				<span class="kicker">Articles</span>
				<h2 class="section-title">À lire</h2>
			</div>
			<a class="section-cta" href="/articles">
				Tous les articles <Fragment set:html={iconSvg('arrow-right', 16)} />
			</a>
		</div>
		<div class="grid-3">
			{latestArticles.map((article) => <ArticleCard article={article} />)}
		</div>
	</section>
</BaseLayout>
)}

<style>
	.hero-section {
		padding-top: var(--space-10);
	}

	.hero-header {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		margin-bottom: var(--space-5);
	}

	.hero-tagline {
		letter-spacing: 0.04em;
	}

	.section-header-left {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}

	.section-cta {
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		color: var(--navy);
		font-size: var(--text-sm);
		font-weight: var(--fw-semibold);
		letter-spacing: 0.06em;
		text-transform: uppercase;
		white-space: nowrap;
		flex-shrink: 0;
	}

	/* Videos — large lead left (58%), stacked column right (42%) */
	.videos-section {
		padding-bottom: var(--space-20);
	}

	.videos-lead {
		display: grid;
		grid-template-columns: minmax(0, 58fr) minmax(0, 42fr);
		gap: var(--space-8);
		align-items: start;
	}

	.videos-lead-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		gap: var(--space-6);
	}

	/* Feature band */
	.feature-band {
		background: var(--navy-050);
	}

	.feature-section {
		display: flex;
		flex-direction: column;
		gap: var(--space-6);
	}

	/* Articles section */
	.articles-section {
		padding-top: var(--space-20);
	}

	@media (max-width: 860px) {
		.videos-lead {
			grid-template-columns: 1fr;
		}

		.videos-lead-grid {
			grid-template-columns: 1fr 1fr;
		}
	}

	@media (max-width: 640px) {
		.hero-header {
			flex-direction: column;
			gap: var(--space-2);
		}

		.videos-lead-grid {
			grid-template-columns: 1fr;
		}

		.videos-lead-card :global(.video-card--lg .video-title) {
			font-size: var(--text-lg);
		}

		.feature-section {
			gap: var(--space-4);
		}
	}
</style>
