---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { iconSvg } from '../../lib/icons';
---

<BaseLayout title="Search" description="Search articles and videos on Travel-Îles." locale="en" alternateUrl="/recherche">
	<section class="container-wide search-page">
		<header class="search-header">
			<span class="kicker">Search</span>
			<h1 class="page-title">Search</h1>
		</header>

		<form class="search-bar" role="search">
			<span class="search-icon"><Fragment set:html={iconSvg('search', 22)} /></span>
			<label class="sr-only" for="site-search">Search</label>
			<input id="site-search" name="q" type="search" placeholder="A place, a theme, a section..." autocomplete="off" />
		</form>

		<div class="results-meta" id="results-meta"></div>
		<div id="search-results" class="search-results grid-3" aria-live="polite"></div>
		<p class="search-hint" id="search-hint">
			Try "rum", "Grand Baie", "Flavours"...
		</p>
	</section>
</BaseLayout>

<script>
	import Fuse from 'fuse.js';

	type SearchItem = {
		title: string;
		excerpt: string;
		category: string;
		date: string;
		url: string;
		type: 'article' | 'video';
		cover?: string;
		thumbnail?: string;
	};

	let fuse: Fuse<SearchItem> | undefined;

	function formatDate(value: string) {
		return new Intl.DateTimeFormat('en-GB', {
			day: 'numeric',
			month: 'long',
			year: 'numeric',
		}).format(new Date(value));
	}

	function renderCard(item: SearchItem) {
		const image = item.type === 'article' ? item.cover : item.thumbnail;
		const typeLabel = item.type === 'article' ? 'Article' : 'Video';
		return `
			<a class="result-card" href="${item.url}">
				${image ? `<div class="result-image"><img src="${image}" alt="" loading="lazy" /></div>` : ''}
				<div class="result-body">
					<span class="result-type">${typeLabel} · ${item.category}</span>
					<h3 class="result-title">${item.title}</h3>
					<span class="meta">${formatDate(item.date)}</span>
				</div>
			</a>
		`;
	}

	async function setupSearch() {
		const input = document.querySelector<HTMLInputElement>('#site-search');
		const container = document.querySelector<HTMLElement>('#search-results');
		const meta = document.getElementById('results-meta');
		const hint = document.getElementById('search-hint');

		if (!input || !container) return;

		if (!fuse) {
			const response = await fetch('/en/search-index.json');
			const items: SearchItem[] = await response.json();
			fuse = new Fuse(items, {
				keys: ['title', 'excerpt', 'category', 'type'],
				threshold: 0.35,
				ignoreLocation: true,
			});
		}

		let timer: ReturnType<typeof setTimeout>;
		const update = () => {
			window.clearTimeout(timer);
			timer = window.setTimeout(() => {
				const query = input.value.trim();

				if (!query) {
					container.innerHTML = '';
					if (meta) meta.textContent = '';
					if (hint) { hint.textContent = 'Try "rum", "Grand Baie", "Flavours"...'; hint.hidden = false; }
					return;
				}

				const results = fuse!.search(query).map((r) => r.item).slice(0, 12);

				if (results.length === 0) {
					container.innerHTML = '';
					if (meta) meta.textContent = '';
					if (hint) { hint.textContent = `No results for "${query}".`; hint.hidden = false; }
					return;
				}

				if (hint) hint.hidden = true;
				if (meta) meta.textContent = `${results.length} result${results.length > 1 ? 's' : ''}`;
				container.innerHTML = results.map(renderCard).join('');
			}, 120);
		};

		input.addEventListener('input', update);
	}

	document.addEventListener('astro:page-load', setupSearch);
	setupSearch();
</script>

<style>
	.search-page { padding-top: var(--space-16); padding-bottom: var(--space-20); min-height: 60vh; }
	.search-header { display: flex; flex-direction: column; gap: var(--space-5); max-width: 52rem; margin-bottom: var(--space-8); }
	.search-bar { position: relative; display: flex; align-items: center; border-bottom: 1px solid var(--ink); padding-bottom: 0.75rem; margin-bottom: var(--space-10); }
	.search-icon { display: flex; color: var(--text-muted); flex-shrink: 0; margin-right: var(--space-3); }
	.search-bar input { width: 100%; border: 0; background: transparent; padding: 0.5rem 0; color: var(--ink); font-family: var(--font-body); font-size: var(--text-lg); font-weight: var(--fw-normal); line-height: 1.2; }
	.search-bar input::placeholder { color: var(--text-muted); }
	.search-bar input:focus { outline: none; }
	.results-meta { color: var(--text-muted); font-size: var(--text-sm); letter-spacing: 0.04em; margin-bottom: var(--space-6); }
	.search-hint { text-align: center; color: var(--text-muted); font-size: var(--text-lg); padding: var(--space-12) 0; }
	.search-results :global(.result-card) { display: flex; flex-direction: column; gap: var(--space-3); color: inherit; }
	.search-results :global(.result-image) { aspect-ratio: 3 / 2; overflow: hidden; border-radius: var(--radius-xs); background: var(--surface-sunken); }
	.search-results :global(.result-image img) { width: 100%; height: 100%; object-fit: cover; }
	.search-results :global(.result-body) { display: flex; flex-direction: column; gap: var(--space-2); }
	.search-results :global(.result-type) { font-size: var(--text-xs); font-weight: var(--fw-semibold); letter-spacing: 0.1em; text-transform: uppercase; color: var(--navy); }
	.search-results :global(.result-title) { font-family: var(--font-display); font-size: var(--text-lg); font-weight: var(--fw-medium); line-height: var(--leading-snug); color: var(--text-heading); }
	.search-results :global(.result-card:hover .result-title) { color: var(--navy); }
</style>
