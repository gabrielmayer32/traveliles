---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { iconSvg } from '../../lib/icons';
---

<BaseLayout title="About" description="About Travel-Îles." locale="en" alternateUrl="/a-propos">
	<section class="container-wide about-page">
		<header class="about-header">
			<span class="kicker">About</span>
			<h1 class="page-title">The gaze, the place, the time.</h1>
		</header>

		<div class="prose about-prose">
			<p>Travel-Îles is an independent magazine dedicated to exceptional travel, hospitality, dining, craftsmanship, and the landscapes that define Mauritian art de vivre.</p>
			<p>We cover addresses that take their time: characterful hotels, private villas, chefs, artisans, artists, golf courses, preserved lagoons, and still-undiscovered territories.</p>
			<p>Each subject favours the editorial gaze, quality of detail, and a genuine relationship with place.</p>
		</div>

		<div class="about-cta">
			<a class="btn-primary" href="/en/contact">
				Write to us <Fragment set:html={iconSvg('mail', 16)} />
			</a>
		</div>
	</section>
</BaseLayout>

<style>
	.about-page { padding-top: var(--space-16); padding-bottom: var(--space-20); }
	.about-header { display: flex; flex-direction: column; gap: var(--space-5); margin-bottom: var(--space-10); }
	.about-prose { max-width: var(--prose-width); }
	.about-cta { margin-top: var(--space-12); }
	.btn-primary { display: inline-flex; align-items: center; gap: 0.5em; font-family: var(--font-body); font-size: var(--text-sm); font-weight: var(--fw-semibold); letter-spacing: var(--tracking-wide); text-transform: uppercase; color: var(--white); background: var(--navy); border: none; border-radius: var(--radius-xs); padding: 0.85em 1.6em; transition: background var(--dur-fast) var(--ease-out); }
	.btn-primary:hover { background: var(--navy-900); }
</style>
