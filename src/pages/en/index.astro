---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import HeroVideo from '../../components/HeroVideo.astro';
import PartnersBar from '../../components/PartnersBar.astro';
import VideoCard from '../../components/VideoCard.astro';
import { iconSvg } from '../../lib/icons';
import { t } from '../../lib/i18n';

const locale = 'en' as const;

const allPublishedArticles = (await getCollection('articles_en'))
	.filter((a) => a.data.published && !!a.data.title)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Articles section excludes News
const articles = allPublishedArticles.filter((a) => a.data.category !== 'News');

const allVideos = (await getCollection('videos'))
	.filter((v) => v.data.published)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const leadVideo = allVideos[0];
const gridVideos = allVideos.slice(1, 3);

const heroEntries = await getCollection('hero');
const heroEntry = heroEntries.find((h) => h.data.published);

const [featureArticle, ...gridArticles] = articles;
const latestArticles = gridArticles.slice(0, 3);

// News: shuffled randomly at build time
const newsArticles = allPublishedArticles.filter((a) => a.data.category === 'News');
for (let i = newsArticles.length - 1; i > 0; i--) {
	const j = Math.floor(Math.random() * (i + 1));
	[newsArticles[i], newsArticles[j]] = [newsArticles[j], newsArticles[i]];
}
const carouselNews = newsArticles.slice(0, 6);
---

<BaseLayout locale={locale} alternateUrl="/">
	{heroEntry && (
		<section class="container-wide hero-section">
			<HeroVideo hero={heroEntry} />
		</section>
	)}

	{allVideos.length > 0 && (
		<section class="container-wide section videos-section">
			<div class="section-header">
				<div class="section-header-left">
					<h2 class="section-title">{t('home.latest_videos', locale)}</h2>
				</div>
				<a class="section-cta" href="/videos">
					{t('home.all_videos', locale)} <Fragment set:html={iconSvg('arrow-right', 16)} />
				</a>
			</div>

			{leadVideo && (
				<div class="videos-lead">
					<div class="videos-lead-card">
						<VideoCard video={leadVideo} size="lg" locale="fr" />
					</div>
					{gridVideos.length > 0 && (
						<div class="videos-lead-grid">
							{gridVideos.map((v) => <VideoCard video={v} size="sm" locale="fr" />)}
						</div>
					)}
				</div>
			)}
		</section>
	)}

	{featureArticle && (
		<section class="feature-band">
			<div class="container-wide section feature-section">
				<div class="feature-label">
					<span class="kicker">{t('home.reading', locale)}</span>
				</div>
				<ArticleCard article={featureArticle} orientation="horizontal" size="lg" locale={locale} />
			</div>
		</section>
	)}

	{latestArticles.length > 0 && (
		<section class="container-wide section articles-section">
			<div class="section-header">
				<div class="section-header-left">
					<h2 class="section-title">Articles</h2>
				</div>
				<a class="section-cta" href="/en/articles">
					{t('home.all_articles', locale)} <Fragment set:html={iconSvg('arrow-right', 16)} />
				</a>
			</div>
			<div class="grid-3">
				{latestArticles.map((article) => <ArticleCard article={article} locale={locale} />)}
			</div>
		</section>
	)}

	{articles.length === 0 && (
		<section class="container-wide empty-en">
			<p>English content coming soon. <a href="/">Visit the French edition →</a></p>
		</section>
	)}

	{carouselNews.length > 0 && (
		<section class="container-wide section carousel-section" id="news-carousel">
			<div class="section-header">
				<div class="section-header-left">
					<h2 class="section-title">News</h2>
				</div>
				<div class="carousel-arrows">
					<button class="carousel-arrow news-prev" type="button" aria-label="Previous">
						<Fragment set:html={iconSvg('arrow-left', 20)} />
					</button>
					<button class="carousel-arrow news-next" type="button" aria-label="Next">
						<Fragment set:html={iconSvg('arrow-right', 20)} />
					</button>
				</div>
			</div>
			<div class="carousel-track-wrapper">
				<div class="carousel-track" id="news-track">
					{carouselNews.map((a) => (
						<div class="carousel-slide">
							<ArticleCard article={a} locale={locale} />
						</div>
					))}
				</div>
			</div>
		</section>
	)}

	<PartnersBar locale={locale} />

</BaseLayout>

<style>
	.hero-section { padding-top: var(--space-10); }
	.section-header-left { display: flex; flex-direction: column; gap: var(--space-2); }
	.section-cta {
		display: inline-flex; align-items: center; gap: 0.5em;
		color: var(--navy); font-size: var(--text-sm); font-weight: var(--fw-semibold);
		letter-spacing: 0.06em; text-transform: uppercase; white-space: nowrap; flex-shrink: 0;
	}
	.videos-section { padding-bottom: var(--space-20); }
	.videos-lead { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); gap: var(--space-8); align-items: start; }
	.videos-lead-grid { display: grid; grid-template-columns: minmax(0, 1fr); gap: var(--space-6); }
	.feature-band { background: var(--navy-050); }
	.feature-section { display: flex; flex-direction: column; gap: var(--space-6); }
	.articles-section { padding-top: var(--space-20); }
	.empty-en { padding-block: var(--space-20); text-align: center; color: var(--text-muted); font-size: var(--text-lg); }

	@media (max-width: 860px) {
		.videos-lead { grid-template-columns: 1fr; }
		.videos-lead-grid { grid-template-columns: 1fr 1fr; }
	}
	@media (max-width: 640px) {
		.videos-lead-grid { grid-template-columns: 1fr; }
		.videos-lead-card :global(.video-card--lg .video-title) { font-size: var(--text-lg); }
		.feature-section { gap: var(--space-4); }
	}

	.carousel-section { padding-top: var(--space-8); padding-bottom: var(--space-10); }
	.carousel-arrows { display: flex; gap: var(--space-2); flex-shrink: 0; }
	.carousel-arrow { display: grid; place-items: center; width: 44px; height: 44px; border: 1px solid var(--border-strong); border-radius: var(--radius-pill); background: var(--white); color: var(--ink); cursor: pointer; transition: all var(--dur-fast) var(--ease-out); }
	.carousel-arrow:hover:not(:disabled) { background: var(--navy); border-color: var(--navy); color: var(--white); }
	.carousel-arrow:disabled { opacity: 0.3; cursor: default; }
	.carousel-track-wrapper { overflow: hidden; }
	.carousel-track { display: flex; gap: var(--space-8); transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94); }
	.carousel-slide { flex: 0 0 calc((100% - var(--space-8) * 2) / 3); min-width: 0; }

	@media (max-width: 860px) { .carousel-slide { flex: 0 0 calc((100% - var(--space-8)) / 2); } }
	@media (max-width: 560px) { .carousel-slide { flex: 0 0 100%; } }
</style>

<script>
function setupNewsCarousel() {
	const track = document.querySelector<HTMLElement>('#news-track');
	const prev = document.querySelector<HTMLButtonElement>('.news-prev');
	const next = document.querySelector<HTMLButtonElement>('.news-next');
	if (!track || !prev || !next) return;

	const slides = track.querySelectorAll<HTMLElement>('.carousel-slide');
	if (slides.length === 0) return;

	let index = 0;

	function visibleCount() {
		const w = window.innerWidth;
		if (w <= 560) return 1;
		if (w <= 860) return 2;
		return 3;
	}

	function maxIndex() { return Math.max(0, slides.length - visibleCount()); }

	function update() {
		const gap = parseFloat(getComputedStyle(track!).gap) || 0;
		const offset = index * (slides[0].offsetWidth + gap);
		track!.style.transform = `translateX(-${offset}px)`;
		prev!.disabled = index === 0;
		next!.disabled = index >= maxIndex();
	}

	prev.addEventListener('click', () => { if (index > 0) { index--; update(); } });
	next.addEventListener('click', () => { if (index < maxIndex()) { index++; update(); } });
	window.addEventListener('resize', () => { index = Math.min(index, maxIndex()); update(); });
	update();
}

document.addEventListener('astro:page-load', setupNewsCarousel);
setupNewsCarousel();
</script>
