---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages_en', 'confidentialite');
const { Content } = entry ? await render(entry) : { Content: null };
const title = entry?.data.title ?? 'Privacy policy';
---

<BaseLayout title={title} description="Privacy policy for Travel-Îles." locale="en" alternateUrl="/confidentialite">
	<section class="container-wide legal-page">
		<header class="legal-header">
			<span class="kicker">Privacy</span>
			<h1 class="page-title">{title}</h1>
		</header>

		<div class="prose">
			{Content ? <Content /> : null}
		</div>
	</section>
</BaseLayout>

<style>
	.legal-page { padding-top: var(--space-12); padding-bottom: var(--space-20); }
	.legal-header { display: flex; flex-direction: column; gap: var(--space-4); margin-bottom: var(--space-10); }
	.prose code { font-size: 0.9em; background: var(--surface-sunken); padding: 0.15em 0.4em; border-radius: var(--radius-xs); }
</style>
