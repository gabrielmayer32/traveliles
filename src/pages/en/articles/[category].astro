---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import { CATEGORIES, slugifyCategory } from '../../../lib/utils';
import { t, localizedCategory } from '../../../lib/i18n';

const locale = 'en' as const;

export function getStaticPaths() {
	return CATEGORIES.map((category) => ({
		params: { category: slugifyCategory(category) },
		props: { category },
	}));
}

const { category } = Astro.props;

const articles = (await getCollection('articles_en'))
	.filter((a) => a.data.published && !!a.data.title && a.data.category === category)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const displayCategory = localizedCategory(category, locale);
---

<BaseLayout title={displayCategory} description={`Travel-Îles — ${displayCategory}.`} locale={locale} alternateUrl={`/articles/${slugifyCategory(category)}`}>
	<section class="container-wide listing-page">
		<header class="listing-header">
			<span class="kicker">Section</span>
			<h1 class="page-title">{displayCategory}</h1>
		</header>

		<div class="filter-chips" role="radiogroup" aria-label="Filter by section">
			<a class="chip" href="/en/articles">All</a>
			{CATEGORIES.map((cat) => (
				<a
					class:list={['chip', { 'chip--active': cat === category }]}
					href={`/en/articles/${slugifyCategory(cat)}`}
				>
					{localizedCategory(cat, locale)}
				</a>
			))}
		</div>

		{articles.length > 0 ? (
			<div class="grid-3">
				{articles.map((article) => <ArticleCard article={article} locale={locale} />)}
			</div>
		) : (
			<p class="empty-state">{t('listing.empty', locale)}</p>
		)}
	</section>
</BaseLayout>

<style>
	.listing-page { padding-top: var(--space-12); padding-bottom: var(--space-16); }
	.listing-header { display: flex; flex-direction: column; gap: var(--space-4); padding-bottom: var(--space-8); border-bottom: 1px solid var(--border-strong); margin-bottom: var(--space-8); }
	.listing-header .page-title { font-size: clamp(2.75rem, 8vw, 5.5rem); }
	.filter-chips { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-bottom: var(--space-10); }
	.chip { display: inline-block; font-family: var(--font-body); font-size: var(--text-xs); font-weight: var(--fw-semibold); letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-secondary); background: transparent; border: 1px solid var(--border-subtle); border-radius: var(--radius-pill); padding: 0.55em 1.05em; cursor: pointer; transition: all var(--dur-fast) var(--ease-out); white-space: nowrap; text-decoration: none; }
	.chip:hover { color: var(--navy); border-color: var(--navy); }
	.chip--active { background: var(--navy); color: var(--white); border-color: var(--navy); }
	.chip--active:hover { background: var(--navy-900); border-color: var(--navy-900); color: var(--white); }
	.empty-state { text-align: center; color: var(--text-muted); font-size: var(--text-lg); padding: var(--space-16) 0; }
</style>
