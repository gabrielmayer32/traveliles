---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CategoryLabel from '../../../components/CategoryLabel.astro';
import VideoEmbed from '../../../components/VideoEmbed.astro';
import VideoCard from '../../../components/VideoCard.astro';
import { formatDateLocale } from '../../../lib/i18n';
import { iconSvg } from '../../../lib/icons';

const locale = 'en' as const;

export async function getStaticPaths() {
	const videos = (await getCollection('videos_en')).filter((v) => v.data.published);
	const frVideos = await getCollection('videos');
	return videos.map((video) => ({
		params: { slug: video.id },
		props: { video, hasFr: frVideos.some((f) => f.id === video.id && f.data.published) },
	}));
}

const { video, hasFr } = Astro.props;
const { Content } = await render(video);
const alternateUrl = hasFr ? `/videos/${video.id}` : undefined;

const allVideos = (await getCollection('videos_en'))
	.filter((v) => v.data.published && v.id !== video.id)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const more = allVideos.slice(0, 3);
---

<BaseLayout title={video.data.title} description={video.data.excerpt} ogImage={video.data.thumbnail} locale={locale} alternateUrl={alternateUrl}>
	<div class="video-page">
		<div class="back-wrap">
			<a class="back-link" href="/en/videos">
				<span class="back-arrow"><Fragment set:html={iconSvg('arrow-right', 16)} /></span>
				All videos
			</a>
		</div>

		<header class="video-header">
			<div class="video-header-top">
				<CategoryLabel category={video.data.category} variant="solid" linked={false} locale={locale} />
				<span class="meta video-meta-type">Video · {formatDateLocale(video.data.date, locale)}</span>
			</div>
			<h1>{video.data.title}</h1>
		</header>

		<div class="video-player">
			<VideoEmbed videoSource={video.data.videoSource} videoId={video.data.videoId} title={video.data.title} />
		</div>

		<div class="video-desc">
			<p class="video-excerpt">{video.data.excerpt}</p>
			<div class="prose video-body">
				<Content />
			</div>
			<div class="video-meta-footer meta">
				<span class="video-brand">Travel-Îles</span>
				<span aria-hidden="true">·</span>
				<span>{formatDateLocale(video.data.date, locale)}</span>
			</div>
		</div>
	</div>

	{more.length > 0 && (
		<section class="container-wide section">
			<div class="section-header">
				<h2 class="section-title more-title">More videos</h2>
			</div>
			<div class="grid-3">
				{more.map((v) => <VideoCard video={v} locale={locale} />)}
			</div>
		</section>
	)}
</BaseLayout>

<style>
	.video-page { width: min(100% - 2.5rem, 62rem); margin: 0 auto; padding-top: var(--space-8); }
	.back-wrap { margin-bottom: var(--space-2); }
	.back-link { display: inline-flex; align-items: center; gap: 0.5em; color: var(--text-muted); font-size: var(--text-sm); letter-spacing: 0.04em; margin-bottom: var(--space-8); }
	.back-arrow { display: inline-flex; transform: rotate(180deg); }
	.video-header { text-align: left; display: flex; flex-direction: column; align-items: flex-start; gap: var(--space-4); margin-bottom: var(--space-8); padding-top: var(--space-4); }
	.video-header-top { display: flex; align-items: center; gap: var(--space-3); }
	.video-meta-type { letter-spacing: 0.08em; text-transform: uppercase; font-size: var(--text-xs); font-weight: var(--fw-semibold); color: var(--text-muted); }
	h1 { font-size: clamp(2rem, 4.5vw, 3rem); line-height: 1.06; text-wrap: balance; margin: 0; letter-spacing: -0.01em; }
	.video-player { border-radius: var(--radius-sm); overflow: hidden; background: var(--navy-950); box-shadow: var(--shadow-lg); }
	.video-desc { width: min(100%, 42rem); margin: 0; padding-top: var(--space-10); padding-bottom: var(--space-12); }
	.video-excerpt { font-family: var(--font-display); font-weight: var(--fw-regular); font-size: clamp(1.25rem, 2.2vw, 1.5rem); line-height: 1.5; color: var(--ink); margin: 0; }
	.video-body { max-width: none; margin-top: var(--space-6); color: var(--text-body); }
	.video-meta-footer { display: flex; gap: var(--space-3); align-items: center; margin-top: var(--space-8); padding-top: var(--space-5); border-top: 1px solid var(--border-subtle); }
	.video-brand { color: var(--ink); font-weight: var(--fw-medium); }
	.more-title { font-size: var(--text-2xl); }
</style>
