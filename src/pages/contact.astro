---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Contacter la rédaction de Côte Nord.">
	<section class="section">
		<div class="container">
			<p class="page-kicker">Contact</p>
			<h1 class="page-title">Nous écrire</h1>
			<p class="page-intro">Pour une adresse à proposer, une collaboration éditoriale ou une demande de partenariat, contactez la rédaction.</p>
		</div>
	</section>

	<section class="section contact-body">
		<div class="container prose">
			<p><a href="mailto:bonjour@cotenord.mu">bonjour@cotenord.mu</a></p>
			<p class="meta">// TODO: email</p>
		</div>
	</section>
</BaseLayout>

<style>
	.contact-body {
		padding-top: 0;
	}
</style>
