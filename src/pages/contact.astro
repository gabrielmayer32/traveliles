---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages_fr', 'contact');
const { Content } = entry ? await render(entry) : { Content: null };
const title = entry?.data.title ?? 'Contact';
const email = entry?.data.email ?? 'contact@traveliles.com';
---

<BaseLayout title={title} description="Contacter la rédaction de Travel-Îles.">
	<section class="container-wide contact-page">
		<header class="contact-header">
			<span class="kicker">Contact</span>
			<h1 class="page-title">{title}</h1>
		</header>

		<div class="prose">
			{Content ? <Content /> : null}
			<p><a href={`mailto:${email}`}>{email}</a></p>
		</div>
	</section>
</BaseLayout>

<style>
	.contact-page {
		padding-top: var(--space-10);
		padding-bottom: var(--space-20);
	}

	.contact-header {
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
		margin-bottom: var(--space-10);
	}
</style>
