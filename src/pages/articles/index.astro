---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { CATEGORIES, slugifyCategory } from '../../lib/utils';

const articles = (await getCollection('articles'))
	.filter((article) => article.data.published)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Articles" description="Tous les articles de Travel-Îles.">
	<section class="container-wide listing-page">
		<header class="listing-header">
			<span class="kicker">Lecture</span>
			<h1 class="page-title">Articles</h1>
		</header>

		<div class="filter-chips" role="radiogroup" aria-label="Filtrer par rubrique">
			<button class="chip chip--active" data-category="all">Toutes</button>
			{CATEGORIES.map((cat) => (
				<a class="chip" href={`/articles/${slugifyCategory(cat)}`} data-category={cat}>{cat}</a>
			))}
		</div>

		<div class="grid-3 listing-grid" id="listing-grid">
			{articles.map((article) => (
				<div class="listing-item" data-cat={article.data.category}>
					<ArticleCard article={article} />
				</div>
			))}
		</div>

		<p class="empty-state" id="empty-state" hidden>
			Aucun sujet dans cette rubrique pour le moment.
		</p>
	</section>
</BaseLayout>

<script>
	const chips = document.querySelectorAll<HTMLElement>('.chip');
	const items = document.querySelectorAll<HTMLElement>('.listing-item');
	const emptyState = document.getElementById('empty-state');

	chips.forEach((chip) => {
		chip.addEventListener('click', (e) => {
			e.preventDefault();
			const cat = chip.dataset.category;

			chips.forEach((c) => c.classList.remove('chip--active'));
			chip.classList.add('chip--active');

			let visible = 0;
			items.forEach((item) => {
				const show = cat === 'all' || item.dataset.cat === cat;
				item.hidden = !show;
				if (show) visible++;
			});

			if (emptyState) emptyState.hidden = visible > 0;
		});
	});
</script>

<style>
	.listing-page {
		padding-top: var(--space-12);
		padding-bottom: var(--space-16);
	}

	.listing-header {
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
		padding-bottom: var(--space-8);
		border-bottom: 1px solid var(--border-strong);
		margin-bottom: var(--space-8);
	}

	.listing-header .page-title {
		font-size: clamp(2.75rem, 8vw, 5.5rem);
	}

	.filter-chips {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
		margin-bottom: var(--space-10);
	}

	.chip {
		display: inline-block;
		font-family: var(--font-body);
		font-size: var(--text-xs);
		font-weight: var(--fw-semibold);
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--text-secondary);
		background: transparent;
		border: 1px solid var(--border-subtle);
		border-radius: var(--radius-pill);
		padding: 0.55em 1.05em;
		cursor: pointer;
		transition: all var(--dur-fast) var(--ease-out);
		white-space: nowrap;
		text-decoration: none;
	}

	.chip:hover {
		color: var(--navy);
		border-color: var(--navy);
	}

	.chip--active {
		background: var(--navy);
		color: var(--white);
		border-color: var(--navy);
	}

	.chip--active:hover {
		background: var(--navy-900);
		border-color: var(--navy-900);
		color: var(--white);
	}

	.listing-grid {
		min-height: 200px;
	}

	.listing-item[hidden] {
		display: none;
	}

	.empty-state {
		text-align: center;
		color: var(--text-muted);
		font-size: var(--text-lg);
		padding: var(--space-16) 0;
	}
</style>
