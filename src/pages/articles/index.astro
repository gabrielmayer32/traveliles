---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const articles = (await getCollection('articles'))
	.filter((article) => article.data.published)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Articles" description="Tous les articles de Travel-Îles.">
	<section class="section">
		<div class="container">
			<p class="page-kicker">Magazine</p>
			<h1 class="page-title">Articles</h1>
			<p class="page-intro">Hospitalité, gastronomie, adresses confidentielles et art de vivre à Maurice et dans l’océan Indien.</p>
		</div>
	</section>

	<section class="section">
		<div class="container">
			<div class="grid-3">
				{articles.map((article) => <ArticleCard article={article} />)}
			</div>
		</div>
	</section>
</BaseLayout>
