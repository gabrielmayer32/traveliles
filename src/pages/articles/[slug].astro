---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryLabel from '../../components/CategoryLabel.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { formatDate } from '../../lib/utils';
import { iconSvg } from '../../lib/icons';

export async function getStaticPaths() {
	const articles = (await getCollection('articles')).filter((a) => a.data.published);
	const enArticles = await getCollection('articles_en');
	return articles.map((article) => ({
		params: { slug: article.id },
		props: { article, hasEn: enArticles.some((e) => e.id === article.id && e.data.published) },
	}));
}

const { article, hasEn } = Astro.props;
const { Content } = await render(article);
const alternateUrl = hasEn ? `/en/articles/${article.id}` : undefined;

const allArticles = (await getCollection('articles'))
	.filter((a) => a.data.published && a.id !== article.id)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const related = allArticles.slice(0, 3);
---

<BaseLayout title={article.data.title} description={article.data.excerpt} ogImage={article.data.cover} locale="fr" alternateUrl={alternateUrl}>
	<article>
		<!-- Back link -->
		<div class="back-wrap">
			<a class="back-link" href="/articles">
				<span class="back-arrow"><Fragment set:html={iconSvg('arrow-right', 16)} /></span>
				Tous les articles
			</a>
		</div>

		<!-- Centered title block -->
		<header class="article-header">
			<CategoryLabel category={article.data.category} />
			<h1>{article.data.title}</h1>
			<p class="article-lead">{article.data.excerpt}</p>
			<div class="article-meta meta">
				<span class="article-author">{article.data.author}</span>
				<span aria-hidden="true">·</span>
				<span>{formatDate(article.data.date)}</span>
			</div>
		</header>

		<!-- Hero image — 3:2, contained at 62rem, with caption -->
		{article.data.cover && (
			<figure class="article-figure">
				<div class="article-cover">
					<img src={article.data.cover} alt="" />
				</div>
				<figcaption class="meta article-caption">
					{article.data.category} · Travel-Îles
				</figcaption>
			</figure>
		)}

		<!-- Body — lead paragraph + prose at 40rem -->
		<div class="article-body">
			<div class="prose article-prose">
				<Content />
			</div>

			<!-- Tags footer — ruled -->
			{article.data.tags.length > 0 && (
				<div class="tags-footer">
					<span class="kicker tags-kicker">Sujets</span>
					<div class="tags">
						{article.data.tags.map((tag) => (
							<span class="tag">{tag}</span>
						))}
					</div>
				</div>
			)}
		</div>
	</article>

	{related.length > 0 && (
		<section class="container-wide section">
			<div class="section-header">
				<h2 class="section-title related-title">À lire également</h2>
			</div>
			<div class="grid-3">
				{related.map((r) => <ArticleCard article={r} />)}
			</div>
		</section>
	)}
</BaseLayout>

<style>
	/* Back link */
	.back-wrap {
		width: min(100% - 2.5rem, 46rem);
		margin: 0 auto;
		padding-top: var(--space-8);
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		color: var(--text-muted);
		font-size: var(--text-sm);
		letter-spacing: 0.04em;
		margin-bottom: var(--space-8);
	}

	.back-arrow {
		display: inline-flex;
		transform: rotate(180deg);
	}

	/* Title block — left-aligned, editorial */
	.article-header {
		width: min(100% - 2.5rem, 46rem);
		margin: 0 auto;
		text-align: left;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: var(--space-5);
		padding-top: var(--space-4);
	}

	h1 {
		font-size: clamp(2.25rem, 5.5vw, 4rem);
		line-height: 1.05;
		text-wrap: balance;
		margin: 0;
		letter-spacing: -0.01em;
	}

	.article-lead {
		font-size: var(--text-lg);
		line-height: var(--leading-normal);
		color: var(--text-secondary);
		max-width: 36rem;
		text-wrap: pretty;
		margin: 0;
	}

	.article-meta {
		display: flex;
		gap: var(--space-3);
		align-items: center;
		padding-top: var(--space-4);
		border-top: 1px solid var(--border-subtle);
		width: 100%;
	}

	.article-author {
		color: var(--ink);
		font-weight: var(--fw-medium);
		letter-spacing: 0.02em;
	}

	/* Hero figure */
	.article-figure {
		margin: var(--space-12) auto 0;
		width: min(100% - 2.5rem, 62rem);
	}

	.article-cover {
		aspect-ratio: 3 / 2;
		overflow: hidden;
		border-radius: var(--radius-sm);
		background: var(--surface-sunken);
	}

	.article-cover img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.article-caption {
		margin-top: var(--space-3);
		font-size: var(--text-sm);
		color: var(--text-muted);
		font-style: italic;
	}

	/* Body */
	.article-body {
		width: min(100% - 2.5rem, 40rem);
		margin: 0 auto;
		padding-top: var(--space-16);
		padding-bottom: var(--space-12);
	}

	/* First paragraph rendered as editorial lead in Playfair Display */
	.article-prose :global(p:first-child) {
		font-family: var(--font-display);
		font-weight: var(--fw-regular);
		font-size: clamp(1.375rem, 2.4vw, 1.625rem);
		line-height: 1.5;
		color: var(--ink);
		margin-bottom: var(--space-8);
	}

	.article-prose {
		max-width: none;
	}

	/* Tags footer */
	.tags-footer {
		margin-top: var(--space-12);
		padding-top: var(--space-6);
		border-top: 1px solid var(--border-subtle);
	}

	.tags-kicker {
		display: block;
		margin-bottom: var(--space-4);
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
	}

	.tag {
		display: inline-block;
		font-size: var(--text-xs);
		font-weight: var(--fw-medium);
		letter-spacing: 0.02em;
		color: var(--text-secondary);
		background: var(--surface-sunken);
		border: 1px solid var(--border-subtle);
		border-radius: var(--radius-pill);
		padding: 0.35em 0.85em;
		line-height: 1.3;
	}

	.related-title {
		font-size: var(--text-2xl);
	}
</style>
