---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryLabel from '../../components/CategoryLabel.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { formatDate } from '../../lib/utils';
import { iconSvg } from '../../lib/icons';

export async function getStaticPaths() {
	const articles = (await getCollection('articles')).filter((a) => a.data.published);
	return articles.map((article) => ({
		params: { slug: article.id },
		props: { article },
	}));
}

const { article } = Astro.props;
const { Content } = await render(article);

const allArticles = (await getCollection('articles'))
	.filter((a) => a.data.published && a.id !== article.id)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const related = allArticles.slice(0, 3);
---

<BaseLayout title={article.data.title} description={article.data.excerpt} ogImage={article.data.cover}>
	<div class="container back-link-wrap">
		<a class="back-link" href="/articles">
			<span class="back-arrow"><Fragment set:html={iconSvg('arrow-right', 16)} /></span>
			Tous les articles
		</a>
	</div>

	<article>
		<header class="article-header container">
			<CategoryLabel category={article.data.category} />
			<h1>{article.data.title}</h1>
			<p class="article-lead">{article.data.excerpt}</p>
			<div class="meta article-meta">
				<span class="article-author">{article.data.author}</span>
				<span>·</span>
				<span>{formatDate(article.data.date)}</span>
			</div>
		</header>

		{article.data.cover && (
			<div class="article-cover container-wide">
				<img src={article.data.cover} alt="" />
			</div>
		)}

		<div class="container article-content">
			<div class="prose">
				<Content />
			</div>
			{article.data.tags.length > 0 && (
				<div class="tags">
					{article.data.tags.map((tag) => (
						<span class="tag">{tag}</span>
					))}
				</div>
			)}
		</div>
	</article>

	{related.length > 0 && (
		<section class="container-wide section">
			<div class="section-header">
				<h2 class="section-title related-title">À lire également</h2>
			</div>
			<div class="grid-3">
				{related.map((r) => <ArticleCard article={r} />)}
			</div>
		</section>
	)}
</BaseLayout>

<style>
	.back-link-wrap {
		padding-top: var(--space-10);
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		color: var(--text-muted);
		font-size: var(--text-sm);
		letter-spacing: 0.04em;
		margin-bottom: var(--space-8);
	}

	.back-arrow {
		display: inline-flex;
		transform: rotate(180deg);
	}

	.article-header {
		max-width: 52rem;
		display: flex;
		flex-direction: column;
		gap: var(--space-5);
	}

	h1 {
		font-size: clamp(2.25rem, 6vw, 4rem);
		line-height: 1.04;
	}

	.article-lead {
		font-size: var(--text-lg);
		line-height: var(--leading-normal);
		color: var(--text-secondary);
		max-width: 44rem;
	}

	.article-meta {
		display: flex;
		gap: var(--space-3);
		align-items: center;
		margin-top: var(--space-2);
	}

	.article-author {
		color: var(--ink);
		font-weight: var(--fw-medium);
	}

	.article-cover {
		margin-block: var(--space-12);
		aspect-ratio: 16 / 8;
		overflow: hidden;
		border-radius: var(--radius-sm);
		background: var(--surface-sunken);
	}

	.article-cover img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.article-content {
		padding-block: var(--space-4) var(--space-12);
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
		margin-top: var(--space-10);
		max-width: var(--prose-width);
	}

	.tag {
		display: inline-block;
		font-size: var(--text-xs);
		font-weight: var(--fw-medium);
		letter-spacing: 0.02em;
		color: var(--text-secondary);
		background: var(--surface-sunken);
		border: 1px solid var(--border-subtle);
		border-radius: var(--radius-pill);
		padding: 0.35em 0.85em;
		line-height: 1.3;
	}

	.related-title {
		font-size: var(--text-2xl);
	}
</style>
