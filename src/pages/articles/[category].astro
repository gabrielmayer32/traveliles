---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { CATEGORIES, categoryFromSlug, slugifyCategory } from '../../lib/utils';

export function getStaticPaths() {
	return CATEGORIES.map((category) => ({
		params: { category: slugifyCategory(category) },
		props: { category },
	}));
}

const { category } = Astro.props;
const currentSlug = Astro.params.category;

const articles = (await getCollection('articles'))
	.filter((article) => article.data.published && article.data.category === category)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title={category} description={`Articles Travel-Îles — ${category}.`}>
	<section class="container-wide listing-page">
		<header class="listing-header">
			<span class="kicker">Rubrique</span>
			<h1 class="page-title">{category}</h1>
		</header>

		<div class="filter-chips" role="radiogroup" aria-label="Filtrer par rubrique">
			<a class="chip" href="/articles">Toutes</a>
			{CATEGORIES.map((cat) => (
				<a
					class:list={['chip', { 'chip--active': cat === category }]}
					href={`/articles/${slugifyCategory(cat)}`}
				>
					{cat}
				</a>
			))}
		</div>

		{articles.length > 0 ? (
			<div class="grid-3">
				{articles.map((article) => <ArticleCard article={article} />)}
			</div>
		) : (
			<p class="empty-state">
				Aucun sujet dans cette rubrique pour le moment.
			</p>
		)}
	</section>
</BaseLayout>

<style>
	.listing-page {
		padding-top: var(--space-12);
		padding-bottom: var(--space-16);
	}

	.listing-header {
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
		padding-bottom: var(--space-8);
		border-bottom: 1px solid var(--border-strong);
		margin-bottom: var(--space-8);
	}

	.listing-header .page-title {
		font-size: clamp(2.75rem, 8vw, 5.5rem);
	}

	.filter-chips {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
		margin-bottom: var(--space-10);
	}

	.chip {
		display: inline-block;
		font-family: var(--font-body);
		font-size: var(--text-xs);
		font-weight: var(--fw-semibold);
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--text-secondary);
		background: transparent;
		border: 1px solid var(--border-subtle);
		border-radius: var(--radius-pill);
		padding: 0.55em 1.05em;
		cursor: pointer;
		transition: all var(--dur-fast) var(--ease-out);
		white-space: nowrap;
		text-decoration: none;
	}

	.chip:hover {
		color: var(--navy);
		border-color: var(--navy);
	}

	.chip--active {
		background: var(--navy);
		color: var(--white);
		border-color: var(--navy);
	}

	.chip--active:hover {
		background: var(--navy-900);
		border-color: var(--navy-900);
		color: var(--white);
	}

	.empty-state {
		text-align: center;
		color: var(--text-muted);
		font-size: var(--text-lg);
		padding: var(--space-16) 0;
	}
</style>
