---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import CategoryNav from '../../components/CategoryNav.astro';
import VideoCard from '../../components/VideoCard.astro';
import { CATEGORIES, getCategoryParent, getCategoryScope, slugifyCategory, type Category } from '../../lib/utils';

export function getStaticPaths() {
	return CATEGORIES.map((category) => ({
		params: { category: slugifyCategory(category) },
		props: { category },
	}));
}

const { category } = Astro.props as { category: Category };
const parentCategory = getCategoryParent(category);
const categoryScope = getCategoryScope(category);
const articles = (await getCollection('articles'))
	.filter((article) => article.data.published && categoryScope.includes(article.data.category))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const videos = (await getCollection('videos'))
	.filter((video) => video.data.published && categoryScope.includes(video.data.category))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 4);
---

<BaseLayout title={category} description={`Articles Travel-Îles — ${category}.`}>
	<section class="container-wide listing-page">
		<header class="listing-header">
			{parentCategory ? (
				<div class="category-context">
					<a href={`/articles/${slugifyCategory(parentCategory)}`}>{parentCategory}</a>
					<span aria-hidden="true">/</span>
					<span>Sous-rubrique</span>
				</div>
			) : (
				<span class="kicker">Rubrique</span>
			)}
			<h1 class="page-title">{category}</h1>
		</header>

		<CategoryNav active={category} />

		<section class="listing-section">
			<h2 class="subsection-title">Nos dernières vidéos</h2>
			{videos.length > 0 ? (
				<div class="grid-4">
					{videos.map((video) => <VideoCard video={video} />)}
				</div>
			) : (
				<p class="empty-state empty-state--compact">
					Aucune vidéo dans cette rubrique pour le moment.
				</p>
			)}
		</section>

		<section class="listing-section">
			<h2 class="subsection-title">Articles</h2>
			{articles.length > 0 ? (
				<div class="grid-3">
					{articles.map((article) => <ArticleCard article={article} />)}
				</div>
			) : (
				<p class="empty-state">
					Aucun sujet dans cette rubrique pour le moment.
				</p>
			)}
		</section>
	</section>
</BaseLayout>

<style>
	.listing-page {
		padding-top: var(--space-12);
		padding-bottom: var(--space-16);
	}

	.listing-header {
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
		padding-bottom: var(--space-8);
		border-bottom: 1px solid var(--border-strong);
		margin-bottom: var(--space-8);
	}

	.listing-header .page-title {
		font-size: clamp(2rem, 5vw, 3.5rem);
	}

	.category-context {
		display: flex;
		align-items: center;
		gap: var(--space-2);
		font-size: var(--text-sm);
		font-weight: var(--fw-semibold);
		letter-spacing: var(--tracking-wider);
		text-transform: uppercase;
		color: var(--text-muted);
	}

	.category-context a {
		color: var(--navy);
	}

	.listing-section {
		padding-top: var(--space-12);
	}

	.listing-section + .listing-section {
		margin-top: var(--space-12);
		padding-top: var(--space-12);
		border-top: 1px solid var(--border-subtle);
	}

	.subsection-title {
		margin-bottom: var(--space-8);
		font-size: clamp(var(--text-2xl), 4vw, var(--text-3xl));
	}

	.empty-state {
		text-align: center;
		color: var(--text-muted);
		font-size: var(--text-lg);
		padding: var(--space-16) 0;
	}

	.empty-state--compact {
		padding: var(--space-8) 0;
	}
</style>
