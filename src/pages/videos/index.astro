---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryNav from '../../components/CategoryNav.astro';
import VideoCard from '../../components/VideoCard.astro';

const videos = (await getCollection('videos'))
	.filter((v) => v.data.published)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Vidéos" description="Toutes les vidéos de Travel-Îles." locale="fr" alternateUrl="/en/videos">
	<section class="container-wide listing-page">
		<header class="listing-header">
			<span class="kicker">Le magazine vidéo</span>
			<h1 class="page-title">Vidéos</h1>
		</header>

		<CategoryNav mode="filters" />

		<div class="grid-3 listing-grid" id="listing-grid">
			{videos.map((video) => (
				<div class="listing-item" data-cat={video.data.category}>
					<VideoCard video={video} />
				</div>
			))}
		</div>

		<p class="empty-state" id="empty-state" hidden>
			Aucun sujet dans cette rubrique pour le moment.
		</p>
	</section>
</BaseLayout>

<script>
	const chips = document.querySelectorAll<HTMLElement>('.chip');
	const items = document.querySelectorAll<HTMLElement>('.listing-item');
	const emptyState = document.getElementById('empty-state');

	chips.forEach((chip) => {
		chip.addEventListener('click', () => {
			const categories = (chip.dataset.categories ?? '').split('|');

			chips.forEach((c) => c.classList.remove('chip--active'));
			chip.classList.add('chip--active');

			let visible = 0;
			items.forEach((item) => {
				const show = categories.includes('all') || categories.includes(item.dataset.cat ?? '');
				item.hidden = !show;
				if (show) visible++;
			});

			if (emptyState) emptyState.hidden = visible > 0;
		});
	});
</script>

<style>
	.listing-page {
		padding-top: var(--space-12);
		padding-bottom: var(--space-16);
	}

	.listing-header {
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
		padding-bottom: var(--space-8);
		border-bottom: 1px solid var(--border-strong);
		margin-bottom: var(--space-8);
	}

	.listing-header .page-title {
		font-size: clamp(2rem, 5vw, 3.5rem);
	}

	.listing-grid {
		min-height: 200px;
	}

	.listing-item[hidden] {
		display: none;
	}

	.empty-state {
		text-align: center;
		color: var(--text-muted);
		font-size: var(--text-lg);
		padding: var(--space-16) 0;
	}
</style>
