---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryLabel from '../../components/CategoryLabel.astro';
import VideoEmbed from '../../components/VideoEmbed.astro';
import VideoCard from '../../components/VideoCard.astro';
import { formatDate } from '../../lib/utils';
import { iconSvg } from '../../lib/icons';

export async function getStaticPaths() {
	const videos = (await getCollection('videos')).filter((v) => v.data.published);
	return videos.map((video) => ({
		params: { slug: video.id },
		props: { video },
	}));
}

const { video } = Astro.props;
const { Content } = await render(video);

const allVideos = (await getCollection('videos'))
	.filter((v) => v.data.published && v.id !== video.id)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const more = allVideos.slice(0, 3);
---

<BaseLayout title={video.data.title} description={video.data.excerpt} ogImage={video.data.thumbnail}>
	<div class="container-wide video-page">
		<a class="back-link" href="/videos">
			<span class="back-arrow"><Fragment set:html={iconSvg('arrow-right', 16)} /></span>
			Toutes les vidéos
		</a>

		<div class="video-player">
			<VideoEmbed videoSource={video.data.videoSource} videoId={video.data.videoId} title={video.data.title} />
		</div>

		<div class="video-info">
			<div class="video-info-top">
				<CategoryLabel category={video.data.category} variant="solid" linked={false} />
				<span class="meta">Vidéo · {formatDate(video.data.date)}</span>
			</div>
			<h1>{video.data.title}</h1>
			<div class="prose video-body">
				<Content />
			</div>
		</div>
	</div>

	{more.length > 0 && (
		<section class="container-wide section">
			<div class="section-header">
				<h2 class="section-title more-title">À voir aussi</h2>
			</div>
			<div class="grid-3">
				{more.map((v) => <VideoCard video={v} />)}
			</div>
		</section>
	)}
</BaseLayout>

<style>
	.video-page {
		padding-top: var(--space-10);
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		color: var(--text-muted);
		font-size: var(--text-sm);
		letter-spacing: 0.04em;
		margin-bottom: var(--space-8);
	}

	.back-arrow {
		display: inline-flex;
		transform: rotate(180deg);
	}

	.video-player {
		border-radius: var(--radius-sm);
		overflow: hidden;
		background: var(--navy-950);
	}

	.video-info {
		margin-top: var(--space-8);
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-6) var(--space-12);
		align-items: start;
	}

	.video-info-top {
		grid-column: 1 / -1;
		display: flex;
		align-items: center;
		gap: var(--space-3);
	}

	h1 {
		grid-column: 1;
		font-size: clamp(1.875rem, 5vw, 3rem);
		line-height: 1.06;
	}

	.video-body {
		grid-column: 2;
		margin-top: 0;
		max-width: none;
		color: var(--text-secondary);
	}

	.more-title {
		font-size: var(--text-2xl);
	}
</style>
