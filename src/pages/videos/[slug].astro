---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryLabel from '../../components/CategoryLabel.astro';
import VideoEmbed from '../../components/VideoEmbed.astro';
import VideoCard from '../../components/VideoCard.astro';
import { formatDate } from '../../lib/utils';
import { iconSvg } from '../../lib/icons';

export async function getStaticPaths() {
	const videos = (await getCollection('videos')).filter((v) => v.data.published);
	const enVideos = await getCollection('videos_en');
	return videos.map((video) => ({
		params: { slug: video.id },
		props: { video, hasEn: enVideos.some((e) => e.id === video.id && e.data.published) },
	}));
}

const { video, hasEn } = Astro.props;
const { Content } = await render(video);
const alternateUrl = hasEn ? `/en/videos/${video.id}` : undefined;

const allVideos = (await getCollection('videos'))
	.filter((v) => v.data.published && v.id !== video.id)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const more = allVideos.slice(0, 3);
---

<BaseLayout title={video.data.title} description={video.data.excerpt} ogImage={video.data.thumbnail} locale="fr" alternateUrl={alternateUrl}>
	<div class="video-page">
		<!-- Back link -->
		<div class="back-wrap">
			<a class="back-link" href="/videos">
				<span class="back-arrow"><Fragment set:html={iconSvg('arrow-right', 16)} /></span>
				Toutes les vidéos
			</a>
		</div>

		<!-- Centered title block above player -->
		<header class="video-header">
			<div class="video-header-top">
				<CategoryLabel category={video.data.category} variant="solid" linked={false} />
				<span class="meta video-meta-type">Vidéo · {formatDate(video.data.date)}</span>
			</div>
			<h1>{video.data.title}</h1>
		</header>

		<!-- Player — prominent 16:9 -->
		<div class="video-player">
			<VideoEmbed videoSource={video.data.videoSource} videoId={video.data.videoId} title={video.data.title} />
		</div>

		<!-- Description — centered reading measure -->
		<div class="video-desc">
			<p class="video-excerpt">{video.data.excerpt}</p>
			<div class="prose video-body">
				<Content />
			</div>
			<div class="video-meta-footer meta">
				<span class="video-brand">Travel-Îles</span>
				<span aria-hidden="true">·</span>
				<span>{formatDate(video.data.date)}</span>
			</div>
		</div>
	</div>

	{more.length > 0 && (
		<section class="container-wide section">
			<div class="section-header">
				<h2 class="section-title more-title">À voir aussi</h2>
			</div>
			<div class="grid-3">
				{more.map((v) => <VideoCard video={v} />)}
			</div>
		</section>
	)}
</BaseLayout>

<style>
	.video-page {
		width: min(100% - 2.5rem, 62rem);
		margin: 0 auto;
		padding-top: var(--space-8);
	}

	.back-wrap {
		margin-bottom: var(--space-2);
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		color: var(--text-muted);
		font-size: var(--text-sm);
		letter-spacing: 0.04em;
		margin-bottom: var(--space-8);
	}

	.back-arrow {
		display: inline-flex;
		transform: rotate(180deg);
	}

	/* Title block — left-aligned, editorial */
	.video-header {
		text-align: left;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: var(--space-4);
		margin-bottom: var(--space-8);
		padding-top: var(--space-4);
	}

	.video-header-top {
		display: flex;
		align-items: center;
		gap: var(--space-3);
	}

	.video-meta-type {
		letter-spacing: 0.08em;
		text-transform: uppercase;
		font-size: var(--text-xs);
		font-weight: var(--fw-semibold);
		color: var(--text-muted);
	}

	h1 {
		font-size: clamp(2rem, 4.5vw, 3rem);
		line-height: 1.06;
		text-wrap: balance;
		margin: 0;
		letter-spacing: -0.01em;
	}

	/* Player */
	.video-player {
		border-radius: var(--radius-sm);
		overflow: hidden;
		background: var(--navy-950);
		box-shadow: var(--shadow-lg);
	}

	/* Description — left-aligned, reading measure */
	.video-desc {
		width: min(100%, 42rem);
		margin: 0;
		padding-top: var(--space-10);
		padding-bottom: var(--space-12);
	}

	.video-excerpt {
		font-family: var(--font-display);
		font-weight: var(--fw-regular);
		font-size: clamp(1.25rem, 2.2vw, 1.5rem);
		line-height: 1.5;
		color: var(--ink);
		margin: 0;
	}

	.video-body {
		max-width: none;
		margin-top: var(--space-6);
		color: var(--text-body);
	}

	.video-meta-footer {
		display: flex;
		gap: var(--space-3);
		align-items: center;
		margin-top: var(--space-8);
		padding-top: var(--space-5);
		border-top: 1px solid var(--border-subtle);
	}

	.video-brand {
		color: var(--ink);
		font-weight: var(--fw-medium);
	}

	.more-title {
		font-size: var(--text-2xl);
	}
</style>
