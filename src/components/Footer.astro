---
import { CATEGORIES, slugifyCategory } from '../lib/utils';
---

<footer class="site-footer">
	<div class="footer-inner">
		<div>
			<a class="footer-logo" href="/">
				<span class="footer-logo-main">TRAVEL-ÎLES</span>
				<span class="footer-logo-sub">by Côte Nord</span>
			</a>
			<p class="footer-tagline">Tourisme & art de vivre à l’île Maurice et les îles de l’océan Indien.</p>
			<!-- TODO: newsletter, bilingual, partners -->
		</div>
		<nav class="footer-nav" aria-label="Navigation secondaire">
			<a href="/articles">Articles</a>
			{CATEGORIES.map((category) => <a href={`/articles/${slugifyCategory(category)}`}>{category}</a>)}
			<a href="/videos">Vidéos</a>
			<a href="/a-propos">À propos</a>
			<a href="/contact">Contact</a>
		</nav>
	</div>
	<div class="footer-bottom">
		<p>© {new Date().getFullYear()} Travel-Îles by Côte Nord. Tous droits réservés.</p>
	</div>
</footer>

<style>
	.site-footer {
		margin-top: var(--space-16);
		border-top: 1px solid var(--color-grey-light);
		background: var(--color-white);
	}

	.footer-inner {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(16rem, 2fr);
		gap: var(--space-12);
		width: min(100% - 2rem, var(--max-width));
		margin-inline: auto;
		padding-block: var(--space-12);
	}

	.footer-logo {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		color: var(--color-ink);
	}

	.footer-logo-main {
		font-family: var(--font-display);
		font-size: 1.35rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		line-height: 1;
	}

	.footer-logo-sub {
		font-family: var(--font-body);
		font-size: 0.6rem;
		font-weight: 500;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--color-grey-muted);
		margin-top: 0.15rem;
	}

	.footer-tagline {
		max-width: 22rem;
		margin-top: var(--space-4);
		color: #555;
	}

	.footer-nav {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: var(--space-3) var(--space-8);
		font-size: 0.92rem;
		font-weight: 500;
	}

	.footer-bottom {
		width: min(100% - 2rem, var(--max-width));
		margin-inline: auto;
		border-top: 1px solid var(--color-grey-light);
		padding-block: var(--space-4);
		color: var(--color-grey-muted);
		font-size: 0.85rem;
	}

	@media (max-width: 760px) {
		.footer-inner {
			grid-template-columns: 1fr;
		}

		.footer-nav {
			grid-template-columns: 1fr 1fr;
		}
	}
</style>
