---
import { CATEGORIES, slugifyCategory } from '../lib/utils';
import { iconSvg } from '../lib/icons';
import { t, localizedCategory, localizedPath, type Locale } from '../lib/i18n';

interface Props { locale?: Locale; }
const { locale = 'fr' } = Astro.props;

const half = Math.ceil(CATEGORIES.length / 2);
const colA = CATEGORIES.slice(0, half);
const colB = CATEGORIES.slice(half);
const year = new Date().getFullYear();

const aboutHref  = locale === 'en' ? '/en/about'   : '/a-propos';
const searchHref = locale === 'en' ? '/en/search'  : '/recherche';
const legalHref  = locale === 'en' ? '/en/legal-notice' : '/mentions-legales';
const privacyHref = locale === 'en' ? '/en/privacy' : '/confidentialite';
---

<footer class="site-footer">
	<div class="container-wide footer-main">
		<div class="footer-grid">
			<!-- Brand column -->
			<div class="footer-brand">
				<a class="footer-logo" href={localizedPath('/', locale)} aria-label="Travel-Îles">
					<img class="footer-logo-img" src="/images/logo-travel-iles.png" alt="Travel-Îles" />
					<span class="footer-logo-tagline">{t('footer.tagline', locale)}</span>
				</a>
				<p class="footer-desc">{t('footer.desc', locale)}</p>
				<div class="footer-social">
					{(['youtube', 'instagram', 'facebook'] as const).map((name) => (
						<a href="#" aria-label={name} class="social-icon">
							<Fragment set:html={iconSvg(name, 18)} />
						</a>
					))}
				</div>
			</div>

			<!-- Rubriques (2 columns) -->
			<nav class="footer-rubriques">
				<div class="footer-col-title">{t('footer.sections', locale)}</div>
				<div class="footer-rubriques-grid">
					<div>
						{colA.map((category) => (
							<a class="footer-link" href={localizedPath(`/articles/${slugifyCategory(category)}`, locale)}>
								{localizedCategory(category, locale)}
							</a>
						))}
					</div>
					<div>
						{colB.map((category) => (
							<a class="footer-link" href={localizedPath(`/articles/${slugifyCategory(category)}`, locale)}>
								{localizedCategory(category, locale)}
							</a>
						))}
					</div>
				</div>
			</nav>

			<nav class="footer-magazine">
				<a class="footer-link" href={localizedPath('/videos', locale)}>{t('footer.videos', locale)}</a>
				<a class="footer-link" href={localizedPath('/articles', locale)}>{t('footer.articles', locale)}</a>
				<a class="footer-link" href={aboutHref}>{t('footer.about', locale)}</a>
				<a class="footer-link" href={localizedPath('/contact', locale)}>{t('footer.contact', locale)}</a>
				<a class="footer-link" href={searchHref}>{t('footer.search', locale)}</a>
			</nav>

			<!-- Newsletter (placeholder — form will be added later) -->
			<div class="footer-newsletter"></div>
		</div>

		<!-- Bottom bar -->
		<div class="footer-bottom">
			<span>© {year} Travel-Îles. {t('footer.rights', locale)}</span>
			<span class="footer-legal">
				<a href={legalHref}>{t('footer.legal', locale)}</a>
				<a href={privacyHref}>{t('footer.privacy', locale)}</a>
			</span>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		background: var(--navy-950);
		color: var(--white);
	}

	.footer-main {
		padding-block: var(--space-20);
	}

	.footer-grid {
		display: grid;
		grid-template-columns: 1.4fr 1fr 0.6fr 1.2fr;
		gap: var(--space-10);
	}

	.footer-logo {
		display: inline-flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.3em;
		color: var(--white);
		line-height: 1;
	}

	.footer-logo-tagline {
		font-family: var(--font-body);
		font-weight: var(--fw-bold);
		font-size: 0.5rem;
		letter-spacing: 0.085em;
		text-transform: uppercase;
		line-height: 1.15;
		color: rgba(255, 255, 255, 0.7);
		order: -1;
	}

	.footer-logo-img {
		height: 1.6rem;
		width: auto;
		display: block;
		filter: invert(1);
	}

	.footer-desc {
		margin-top: var(--space-5);
		max-width: 26ch;
		color: rgba(255, 255, 255, 0.66);
		font-size: var(--text-sm);
		line-height: var(--leading-normal);
	}

	.footer-social {
		display: flex;
		gap: var(--space-3);
		margin-top: var(--space-6);
	}

	.social-icon {
		display: grid;
		place-items: center;
		width: 40px;
		height: 40px;
		color: rgba(255, 255, 255, 0.85);
		border: 1px solid rgba(255, 255, 255, 0.2);
		border-radius: var(--radius-pill);
		transition: border-color var(--dur-fast) var(--ease-out);
	}

	.social-icon:hover {
		border-color: rgba(255, 255, 255, 0.5);
		color: var(--white);
	}

	.footer-col-title {
		font-family: var(--font-body);
		font-size: var(--text-xs);
		font-weight: var(--fw-semibold);
		letter-spacing: var(--tracking-wider);
		text-transform: uppercase;
		color: var(--white);
		margin-bottom: var(--space-4);
	}

	.footer-rubriques {
		grid-column: span 2;
	}

	.footer-rubriques-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0 var(--space-8);
	}

	.footer-link {
		display: block;
		color: rgba(255, 255, 255, 0.72);
		font-size: var(--text-sm);
		line-height: 1.6;
		padding-block: 0.28em;
	}

	.footer-link:hover {
		color: var(--white);
	}

	.footer-bottom {
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: var(--space-4);
		margin-top: var(--space-16);
		padding-top: var(--space-6);
		border-top: 1px solid rgba(255, 255, 255, 0.14);
		color: rgba(255, 255, 255, 0.5);
		font-size: var(--text-xs);
		letter-spacing: 0.02em;
	}

	.footer-legal {
		display: flex;
		gap: var(--space-5);
	}

	.footer-legal a {
		color: inherit;
	}

	.footer-legal a:hover {
		color: rgba(255, 255, 255, 0.8);
	}

	@media (max-width: 900px) {
		.footer-grid {
			grid-template-columns: 1fr 1fr;
		}
	}

	@media (max-width: 560px) {
		.footer-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
