---
import type { CollectionEntry } from 'astro:content';
import { formatDateLocale, type Locale } from '../lib/i18n';
import CategoryLabel from './CategoryLabel.astro';
import { iconSvg } from '../lib/icons';

interface Props {
	video: CollectionEntry<'videos'> | CollectionEntry<'videos_en'>;
	locale?: Locale;
}

const { video, locale = 'fr' } = Astro.props;
const href = locale === 'en' ? `/en/videos/${video.id}` : `/videos/${video.id}`;
const { videoSource, videoId, title, excerpt, category, date } = video.data;

const embedSrc = {
	youtube: `https://www.youtube.com/embed/${videoId}?autoplay=1&mute=1&loop=1&playlist=${videoId}&controls=0&showinfo=0&rel=0&modestbranding=1&playsinline=1&enablejsapi=1&iv_load_policy=3&disablekb=1&end_screen=0`,
	vimeo: `https://player.vimeo.com/video/${videoId}?autoplay=1&muted=1&loop=1&background=1&title=0&byline=0&portrait=0`,
	facebook: `https://www.facebook.com/plugins/video.php?href=${encodeURIComponent(videoId)}&autoplay=true&mute=true`,
	instagram: `https://www.instagram.com/reel/${videoId}/embed/`,
}[videoSource];

const thumbnail = video.data.thumbnail ?? (
	videoSource === 'youtube'
		? `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`
		: undefined
);
---

<section class="hero-video" data-embed-src={embedSrc}>
	<div class="hero-media">
		{thumbnail && <img class="hero-poster" src={thumbnail} alt="" />}
		<div class="hero-iframe-slot"></div>
	</div>
	<div class="hero-scrim"></div>
	<div class="hero-overlay container-wide">
		<CategoryLabel category={category} variant="overlay" linked={false} />
		<h2 class="hero-title"><a href={href}>{title}</a></h2>
		{excerpt && <p class="hero-excerpt">{excerpt}</p>}
		<div class="meta hero-meta">{formatDateLocale(date, locale)}</div>
	</div>
</section>

<script>
	function initHeroVideo() {
		const hero = document.querySelector<HTMLElement>('.hero-video');
		if (!hero || hero.dataset.heroReady === 'true') return;
		hero.dataset.heroReady = 'true';

		const slot = hero.querySelector<HTMLElement>('.hero-iframe-slot');
		const poster = hero.querySelector<HTMLImageElement>('.hero-poster');
		const embedSrc = hero.dataset.embedSrc;
		if (!slot || !embedSrc) return;

		function injectIframe() {
			if (slot.querySelector('iframe')) return;
			const iframe = document.createElement('iframe');
			iframe.className = 'hero-iframe';
			iframe.src = embedSrc!;
			iframe.title = 'Vidéo Travel-Îles';
			iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
			iframe.allowFullscreen = true;
			slot.appendChild(iframe);

			// Non-YouTube: fade poster on iframe load (no API available)
			if (!embedSrc!.includes('youtube.com') && poster) {
				iframe.addEventListener('load', () => {
					setTimeout(() => poster.classList.add('loaded'), 800);
				});
			}

			// Use YouTube IFrame API to hide poster only when playing, and loop on end
			if (embedSrc!.includes('youtube.com')) {
				function attachYTPlayer() {
					const player = new (window as any).YT.Player(iframe, {
						events: {
							onStateChange(event: any) {
								const PLAYING = 1;
								const ENDED = 0;
								if (event.data === PLAYING) {
									// Video is actually running — now safe to hide poster
									if (poster) poster.classList.add('loaded');
								} else if (event.data === ENDED) {
									// Cover end screen with poster instantly, seek & replay
									if (poster) {
										poster.style.transition = 'none';
										poster.style.opacity = '1';
										poster.style.pointerEvents = 'none';
									}
									player.seekTo(0);
									player.playVideo();
									// Fade poster out again once playback resumes
									setTimeout(() => {
										if (poster) {
											poster.style.transition = '';
											poster.style.opacity = '0';
										}
									}, 800);
								}
							}
						}
					});
				}

				if ((window as any).YT && (window as any).YT.Player) {
					attachYTPlayer();
				} else {
					const prev = (window as any).onYouTubeIframeAPIReady;
					(window as any).onYouTubeIframeAPIReady = function() {
						if (prev) prev();
						attachYTPlayer();
					};
					if (!document.querySelector('script[src*="youtube.com/iframe_api"]')) {
						const tag = document.createElement('script');
						tag.src = 'https://www.youtube.com/iframe_api';
						document.head.appendChild(tag);
					}
				}
			}
		}

		const consent = localStorage.getItem('ti-cookies');
		if (consent === 'accepted') {
			injectIframe();
		} else {
			document.addEventListener('ti:cookies-accepted', () => injectIframe(), { once: true });
		}
	}

	document.addEventListener('astro:page-load', initHeroVideo);
	initHeroVideo();
</script>

<style>
	.hero-video {
		position: relative;
		background: var(--navy-950);
		overflow: hidden;
		border-radius: var(--radius-sm);
	}

	.hero-media {
		position: relative;
		height: clamp(420px, 62vh, 640px);
	}

	.hero-poster {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		z-index: 3;
		transition: opacity 800ms var(--ease-out);
	}

	.hero-poster.loaded {
		opacity: 0;
		pointer-events: none;
	}

	.hero-iframe-slot {
		position: absolute;
		inset: 0;
		z-index: 1;
	}

	.hero-iframe-slot :global(.hero-iframe) {
		position: absolute;
		top: 50%;
		left: 50%;
		width: 100vw;
		min-width: 100%;
		height: 56.25vw;
		min-height: 100%;
		border: 0;
		pointer-events: none;
		transform: translate(-50%, -50%) scale(1.25);
	}

	.hero-scrim {
		position: absolute;
		inset: 0;
		z-index: 4;
		background: linear-gradient(
			to top,
			rgba(20, 26, 63, 0.78) 0%,
			rgba(20, 26, 63, 0.28) 46%,
			rgba(20, 26, 63, 0.10) 100%
		);
		pointer-events: none;
	}

	.hero-overlay {
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		z-index: 5;
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
		padding-bottom: clamp(1.5rem, 4vw, 3rem);
		max-width: 52rem;
	}

	.hero-title {
		font-size: clamp(2rem, 5vw, 3.75rem);
		line-height: var(--leading-tight);
		text-wrap: balance;
	}

	.hero-title a {
		color: var(--white);
	}

	.hero-title a:hover {
		text-decoration: underline;
		text-underline-offset: 0.15em;
	}

	.hero-excerpt {
		color: rgba(255, 255, 255, 0.9);
		font-size: var(--text-lg);
		line-height: var(--leading-normal);
		max-width: 40rem;
	}

	.hero-meta {
		color: rgba(255, 255, 255, 0.78);
	}

	@media (max-width: 640px) {
		.hero-media {
			height: clamp(320px, 50vh, 420px);
		}

		.hero-excerpt {
			display: none;
		}
	}
</style>
