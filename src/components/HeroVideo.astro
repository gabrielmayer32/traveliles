---
import type { CollectionEntry } from 'astro:content';
import { formatDate, slugifyCategory } from '../lib/utils';
import CategoryLabel from './CategoryLabel.astro';

interface Props {
	video: CollectionEntry<'videos'>;
}

const { video } = Astro.props;
const href = `/videos/${video.id}`;
const { videoSource, videoId, title, excerpt, category, date } = video.data;

const embedSrc = {
	youtube: `https://www.youtube.com/embed/${videoId}?autoplay=1&mute=1&loop=1&playlist=${videoId}&controls=0&showinfo=0&rel=0&modestbranding=1&playsinline=1`,
	vimeo: `https://player.vimeo.com/video/${videoId}?autoplay=1&muted=1&loop=1&background=1&title=0&byline=0&portrait=0`,
	facebook: `https://www.facebook.com/plugins/video.php?href=${encodeURIComponent(videoId)}&autoplay=true&mute=true`,
	instagram: `https://www.instagram.com/reel/${videoId}/embed/`,
}[videoSource];

const thumbnail = video.data.thumbnail ?? (
	videoSource === 'youtube'
		? `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`
		: undefined
);
---

<article class="hero-video">
	<div class="hero-media">
		{thumbnail && <img class="hero-poster" src={thumbnail} alt="" />}
		<iframe
			class="hero-iframe"
			src={embedSrc}
			title={title}
			allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
			allowfullscreen
		></iframe>
	</div>
	<div class="hero-gradient"></div>
	<div class="hero-overlay">
		<CategoryLabel category={category} linked={false} />
		<h1><a href={href}>{title}</a></h1>
		<p>{excerpt}</p>
		<div class="meta">{formatDate(date)}</div>
	</div>
</article>

<script>
	function initHeroVideo() {
		const iframe = document.querySelector<HTMLIFrameElement>('.hero-video .hero-iframe');
		const poster = document.querySelector<HTMLImageElement>('.hero-video .hero-poster');
		if (!iframe || !poster) return;

		iframe.addEventListener('load', () => {
			poster.classList.add('loaded');
		});
	}

	document.addEventListener('astro:page-load', initHeroVideo);
	initHeroVideo();
</script>

<style>
	.hero-video {
		position: relative;
		background: var(--color-ink);
		overflow: hidden;
	}

	.hero-media {
		position: relative;
		min-height: min(76vh, 48rem);
	}

	.hero-poster {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0.76;
		z-index: 2;
		transition: opacity 800ms ease;
	}

	.hero-poster.loaded {
		opacity: 0;
		pointer-events: none;
	}

	.hero-iframe {
		position: absolute;
		inset: -20% -10%;
		width: 120%;
		height: 140%;
		border: 0;
		z-index: 1;
		pointer-events: none;
	}

	.hero-overlay {
		position: absolute;
		inset: auto 0 0;
		z-index: 3;
		display: grid;
		gap: var(--space-4);
		width: min(100% - 2rem, var(--max-width));
		margin-inline: auto;
		padding-bottom: clamp(2rem, 8vw, 6rem);
		background: linear-gradient(transparent, rgba(0, 0, 0, 0.65) 40%);
		padding-top: 8rem;
	}

	h1 {
		max-width: 58rem;
		font-size: clamp(3rem, 8vw, 5rem);
	}

	h1 a {
		color: var(--color-white);
	}

	h1 a:hover {
		text-decoration: underline;
		text-underline-offset: 0.15em;
	}

	p {
		max-width: 42rem;
		color: var(--color-white);
		font-size: clamp(1rem, 2vw, 1.25rem);
		line-height: 1.55;
	}

	.meta {
		color: rgba(255, 255, 255, 0.78);
	}

	:global(.hero-video .category-label) {
		color: var(--color-white) !important;
	}

	@media (max-width: 640px) {
		.hero-media {
			min-height: 34rem;
		}

		.hero-overlay {
			width: min(100% - 1.25rem, var(--max-width));
		}
	}
</style>
