---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../lib/utils';
import CategoryLabel from './CategoryLabel.astro';

interface Props {
	video: CollectionEntry<'videos'>;
}

const { video } = Astro.props;
const href = `/videos/${video.id}`;
const { videoSource, videoId, title, excerpt, category, date } = video.data;

const embedSrc = {
	youtube: `https://www.youtube.com/embed/${videoId}?autoplay=1&mute=1&loop=1&playlist=${videoId}&controls=0&showinfo=0&rel=0&modestbranding=1&playsinline=1&enablejsapi=1&iv_load_policy=3&disablekb=1`,
	vimeo: `https://player.vimeo.com/video/${videoId}?autoplay=1&muted=1&loop=1&background=1&title=0&byline=0&portrait=0`,
	facebook: `https://www.facebook.com/plugins/video.php?href=${encodeURIComponent(videoId)}&autoplay=true&mute=true`,
	instagram: `https://www.instagram.com/reel/${videoId}/embed/`,
}[videoSource];

const thumbnail = video.data.thumbnail ?? (
	videoSource === 'youtube'
		? `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`
		: undefined
);
---

<section class="hero-video">
	<div class="hero-media">
		{thumbnail && <img class="hero-poster" src={thumbnail} alt="" />}
		<iframe
			class="hero-iframe"
			src={embedSrc}
			title={title}
			allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
			allowfullscreen
		></iframe>
	</div>
	<div class="hero-scrim"></div>
	<div class="hero-overlay container-wide">
		<CategoryLabel category={category} variant="overlay" linked={false} />
		<h2 class="hero-title"><a href={href}>{title}</a></h2>
		{excerpt && <p class="hero-excerpt">{excerpt}</p>}
		<div class="meta hero-meta">{formatDate(date)}</div>
	</div>
</section>

<script>
	function initHeroVideo() {
		const hero = document.querySelector<HTMLElement>('.hero-video');
		if (!hero || hero.dataset.heroReady === 'true') return;
		hero.dataset.heroReady = 'true';

		const iframe = hero.querySelector<HTMLIFrameElement>('.hero-iframe');
		const poster = hero.querySelector<HTMLImageElement>('.hero-poster');
		if (!iframe || !poster) return;

		iframe.addEventListener('load', () => {
			setTimeout(() => poster.classList.add('loaded'), 600);
		});
	}
	document.addEventListener('astro:page-load', initHeroVideo);
	initHeroVideo();
</script>

<style>
	.hero-video {
		position: relative;
		background: var(--navy-950);
		overflow: hidden;
		border-radius: var(--radius-sm);
	}

	.hero-media {
		position: relative;
		height: clamp(420px, 62vh, 640px);
	}

	.hero-poster {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		z-index: 3;
		transition: opacity 800ms var(--ease-out);
	}

	.hero-poster.loaded {
		opacity: 0;
		pointer-events: none;
	}

	.hero-iframe {
		position: absolute;
		inset: -20% -10%;
		width: 120%;
		height: 140%;
		border: 0;
		z-index: 1;
		pointer-events: none;
	}

	.hero-scrim {
		position: absolute;
		inset: 0;
		z-index: 4;
		background: linear-gradient(
			to top,
			rgba(20, 26, 63, 0.78) 0%,
			rgba(20, 26, 63, 0.28) 46%,
			rgba(20, 26, 63, 0.10) 100%
		);
		pointer-events: none;
	}

	.hero-overlay {
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		z-index: 5;
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
		padding-bottom: clamp(1.5rem, 4vw, 3rem);
		max-width: 52rem;
	}

	.hero-title {
		font-size: clamp(2rem, 5vw, 3.75rem);
		line-height: var(--leading-tight);
		text-wrap: balance;
	}

	.hero-title a {
		color: var(--white);
	}

	.hero-title a:hover {
		text-decoration: underline;
		text-underline-offset: 0.15em;
	}

	.hero-excerpt {
		color: rgba(255, 255, 255, 0.9);
		font-size: var(--text-lg);
		line-height: var(--leading-normal);
		max-width: 40rem;
	}

	.hero-meta {
		color: rgba(255, 255, 255, 0.78);
	}

	@media (max-width: 640px) {
		.hero-media {
			height: clamp(320px, 50vh, 420px);
		}
	}
</style>
