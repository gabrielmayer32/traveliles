---
import type { CollectionEntry } from 'astro:content';

interface Props {
	hero: CollectionEntry<'hero'>;
}

const { hero } = Astro.props;
const { title, label, excerpt, videoFile, poster } = hero.data;
---

<section class="hero-video">
	<div class="hero-media">
		<canvas class="hero-canvas" aria-hidden="true"></canvas>
		<video
			class="hero-r2"
			src={videoFile}
			poster={poster}
			autoplay
			muted
			loop
			playsinline
			preload="auto"
			aria-hidden="true"
		/>
	</div>
	<div class="hero-scrim"></div>
	<div class="hero-overlay container-wide">
		{label && <span class="hero-label">{label}</span>}
		<h2 class="hero-title">{title}</h2>
		{excerpt && <p class="hero-excerpt">{excerpt}</p>}
	</div>
</section>

<script>
	const video = document.querySelector('.hero-r2') as HTMLVideoElement | null;
	const canvas = document.querySelector('.hero-canvas') as HTMLCanvasElement | null;

	const CACHE_KEY = 'hero-poster-' + (video?.src ?? '');

	function showCached() {
		const cached = sessionStorage.getItem(CACHE_KEY);
		if (cached && canvas) {
			const img = new Image();
			img.onload = () => {
				canvas.width = img.naturalWidth;
				canvas.height = img.naturalHeight;
				canvas.getContext('2d')?.drawImage(img, 0, 0);
			};
			img.src = cached;
		}
	}

	function captureFrame() {
		if (!video || !canvas) return;
		canvas.width = video.videoWidth;
		canvas.height = video.videoHeight;
		canvas.getContext('2d')?.drawImage(video, 0, 0);
		try {
			const dataUrl = canvas.toDataURL('image/jpeg', 0.85);
			sessionStorage.setItem(CACHE_KEY, dataUrl);
		} catch {}
	}

	if (video && canvas) {
		showCached();
		video.addEventListener('seeked', () => {
			captureFrame();
			video.play();
		}, { once: true });
		video.addEventListener('loadeddata', () => {
			video.currentTime = 0.001;
		}, { once: true });
		video.addEventListener('playing', () => {
			canvas.style.opacity = '0';
		}, { once: true });
	}
</script>

<style>
	.hero-video {
		position: relative;
		overflow: hidden;
		border-radius: var(--radius-sm);
	}

	.hero-media {
		position: relative;
		height: clamp(420px, 62vh, 640px);
		background: #141a3f;
	}

	.hero-canvas {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		z-index: 2;
		transition: opacity 0.4s ease;
	}

	.hero-r2 {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		z-index: 1;
	}

	.hero-scrim {
		position: absolute;
		inset: 0;
		z-index: 4;
		background: linear-gradient(
			to top,
			rgba(20, 26, 63, 0.78) 0%,
			rgba(20, 26, 63, 0.28) 46%,
			rgba(20, 26, 63, 0.10) 100%
		);
		pointer-events: none;
	}

	.hero-overlay {
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		z-index: 5;
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
		padding-bottom: clamp(1.5rem, 4vw, 3rem);
		max-width: 52rem;
	}

	.hero-label {
		display: inline-block;
		font-size: var(--text-xs);
		font-weight: var(--fw-semibold);
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.7);
	}

	.hero-title {
		font-size: clamp(2rem, 5vw, 3.75rem);
		line-height: var(--leading-tight);
		text-wrap: balance;
		color: var(--white);
	}

	.hero-excerpt {
		color: rgba(255, 255, 255, 0.9);
		font-size: var(--text-lg);
		line-height: var(--leading-normal);
		max-width: 40rem;
	}

	@media (max-width: 640px) {
		.hero-media {
			height: clamp(320px, 50vh, 420px);
		}

		.hero-excerpt {
			display: none;
		}
	}
</style>
