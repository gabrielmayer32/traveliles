---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../lib/utils';
import CategoryLabel from './CategoryLabel.astro';

interface Props {
	video: CollectionEntry<'videos'>;
}

const { video } = Astro.props;
const href = `/videos/${video.id}`;
const thumbnail = video.data.thumbnail ?? (
	video.data.videoSource === 'youtube'
		? `https://img.youtube.com/vi/${video.data.videoId}/hqdefault.jpg`
		: undefined
);
---

<article class="hero-video">
	<a href={href} class="hero-link" aria-label={video.data.title}>
		{thumbnail && <img src={thumbnail} alt="" />}
		<span class="play-button" aria-hidden="true"></span>
		<div class="hero-overlay">
			<CategoryLabel category={video.data.category} linked={false} />
			<h1>{video.data.title}</h1>
			<p>{video.data.excerpt}</p>
			<div class="meta">{formatDate(video.data.date)}</div>
		</div>
	</a>
</article>

<style>
	.hero-video {
		background: var(--color-ink);
	}

	.hero-link {
		position: relative;
		display: block;
		min-height: min(76vh, 48rem);
		overflow: hidden;
		color: var(--color-white);
	}

	img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0.76;
		transition: transform 260ms ease;
	}

	.hero-link:hover img {
		transform: scale(1.02);
	}

	.play-button {
		position: absolute;
		left: 50%;
		top: 44%;
		width: clamp(4rem, 8vw, 6rem);
		height: clamp(4rem, 8vw, 6rem);
		border: 1px solid var(--color-white);
		transform: translate(-50%, -50%);
	}

	.play-button::after {
		content: '';
		position: absolute;
		left: 42%;
		top: 32%;
		border-block: clamp(0.75rem, 1.4vw, 1rem) solid transparent;
		border-left: clamp(1.1rem, 2vw, 1.55rem) solid var(--color-white);
	}

	.hero-overlay {
		position: absolute;
		inset: auto 0 0;
		display: grid;
		gap: var(--space-4);
		width: min(100% - 2rem, var(--max-width));
		margin-inline: auto;
		padding-bottom: clamp(2rem, 8vw, 6rem);
	}

	h1 {
		max-width: 58rem;
		color: var(--color-white);
		font-size: clamp(3rem, 8vw, 5rem);
	}

	p {
		max-width: 42rem;
		font-size: clamp(1rem, 2vw, 1.25rem);
		line-height: 1.55;
	}

	.meta {
		color: rgba(255, 255, 255, 0.78);
	}

	:global(.hero-video .category-label) {
		color: var(--color-white) !important;
	}

	@media (max-width: 640px) {
		.hero-link {
			min-height: 34rem;
		}

		.play-button {
			top: 36%;
		}

		.hero-overlay {
			width: min(100% - 1.25rem, var(--max-width));
		}
	}
</style>
