---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../lib/utils';
import { formatDateLocale, type Locale } from '../lib/i18n';
import CategoryLabel from './CategoryLabel.astro';

interface Props {
	article: CollectionEntry<'articles'> | CollectionEntry<'articles_en'>;
	orientation?: 'vertical' | 'horizontal';
	size?: 'sm' | 'md' | 'lg';
	locale?: Locale;
}

const { article, orientation = 'vertical', size = 'md', locale = 'fr' } = Astro.props;
const href = locale === 'en' ? `/en/articles/${article.id}` : `/articles/${article.id}`;
const horizontal = orientation === 'horizontal';
---

<a class:list={['article-card', { 'article-card--horizontal': horizontal }, `article-card--${size}`]} href={href}>
	{article.data.cover && (
		<div class="article-image">
			<img src={article.data.cover} alt={article.data.title} loading="lazy" />
		</div>
	)}
	<div class="article-body">
		<CategoryLabel category={article.data.category} linked={false} />
		<h3 class="article-title">{article.data.title}</h3>
		{article.data.excerpt && <p class="article-excerpt">{article.data.excerpt}</p>}
		<div class="meta article-meta">
			{article.data.author}
			{article.data.author && article.data.date ? ' · ' : ''}
			{formatDateLocale(article.data.date, locale)}
		</div>
	</div>
</a>

<style>
	.article-card {
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
		color: inherit;
	}

	.article-card--horizontal {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-10);
		align-items: center;
	}

	.article-image {
		position: relative;
		overflow: hidden;
		aspect-ratio: 3 / 2;
		background: var(--surface-sunken);
		border-radius: var(--radius-xs);
	}

	.article-card--horizontal .article-image {
		aspect-ratio: 3 / 2;
	}

	.article-card--horizontal .article-body {
		gap: var(--space-4);
	}

	.article-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transform: scale(1);
		transition: transform var(--dur-slow) var(--ease-out);
	}

	.article-card:hover .article-image img {
		transform: scale(1.04);
	}

	.article-body {
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
	}

	.article-title {
		font-size: var(--text-xl);
		line-height: var(--leading-snug);
		color: var(--text-heading);
		transition: color var(--dur-fast) var(--ease-out);
		margin: 0;
	}

	.article-card--sm .article-title {
		font-size: var(--text-lg);
	}

	.article-card--lg .article-title {
		font-size: clamp(var(--text-2xl), 3vw, var(--text-3xl));
		line-height: 1.1;
	}

	.article-card--horizontal.article-card--lg .article-excerpt {
		font-size: var(--text-lg);
		line-height: var(--leading-normal);
	}

	@media (max-width: 640px) {
		.article-card--horizontal {
			grid-template-columns: 1fr;
			gap: var(--space-5);
		}
	}

	.article-card:hover .article-title {
		color: var(--navy);
	}

	.article-excerpt {
		color: var(--text-secondary);
		font-size: var(--text-base);
		line-height: var(--leading-normal);
		margin: 0;
	}

	.article-meta {
		margin-top: var(--space-1);
	}
</style>
