---
import { CATEGORIES, slugifyCategory } from '../lib/utils';
import { iconSvg } from '../lib/icons';
import { t, localizedCategory, localizedPath, STATIC_ALTERNATES, type Locale } from '../lib/i18n';

interface Props {
	locale?: Locale;
	alternateUrl?: string;
}
const { locale = 'fr', alternateUrl } = Astro.props;

const otherLocale = locale === 'fr' ? 'en' : 'fr';
const switchHref = alternateUrl ?? STATIC_ALTERNATES[Astro.url.pathname] ?? (locale === 'fr' ? '/en/' : '/');

const navLinks = CATEGORIES.map((category) => ({
	label: localizedCategory(category, locale),
	href: localizedPath(`/articles/${slugifyCategory(category)}`, locale),
}));
---

<header class="site-header">
	<div class="header-inner container-wide">
		<a class="logo" href={localizedPath('/', locale)} aria-label="Travel-Îles, accueil">
			<img class="logo-img" src="/images/logo-travel-iles.png" alt="Travel-Îles" />
		</a>

		<nav class="desktop-nav" aria-label="Navigation principale">
			<div class="rubriques-wrapper">
				<button class="nav-link rubriques-trigger" type="button" aria-expanded="false" aria-controls="rubriques-menu" aria-haspopup="true">
					{t('nav.sections', locale)}
					<span class="chevron" aria-hidden="true">
						<Fragment set:html={iconSvg('chevron-down', 16)} />
					</span>
				</button>
			</div>
			<a class="nav-link" href={localizedPath('/a-propos', locale) === '/en/a-propos' ? '/en/about' : '/a-propos'}>{t('nav.about', locale)}</a>
			<a class="search-btn" href={localizedPath('/recherche', locale) === '/en/recherche' ? '/en/search' : '/recherche'} aria-label={t('nav.search', locale)}>
				<Fragment set:html={iconSvg('search', 20)} />
			</a>
			<a class="lang-switch" href={switchHref} hreflang={otherLocale} aria-label={otherLocale === 'en' ? 'Switch to English' : 'Passer en français'}>
				{otherLocale.toUpperCase()}
			</a>
		</nav>

		<button class="mobile-trigger" type="button" aria-expanded="false" aria-controls="mobile-menu" aria-label="Menu">
			<span class="mobile-trigger-icon" aria-hidden="true">
				<Fragment set:html={iconSvg('menu', 24)} />
			</span>
		</button>
	</div>

	<!-- Rubriques mega-menu -->
	<div id="rubriques-menu" class="rubriques-panel" hidden>
		<div class="container-wide rubriques-panel-inner">
			<div class="rubriques-panel-header">
				<span class="kicker">{t('nav.sections', locale)}</span>
			</div>
			<ul class="rubriques-grid">
				{navLinks.map((link) => (
					<li><a href={link.href}>{link.label}</a></li>
				))}
			</ul>
		</div>
	</div>

	<!-- Mobile panel -->
	<nav id="mobile-menu" class="mobile-nav" aria-label="Navigation mobile" hidden>
		<div class="container mobile-nav-inner">
			<div class="mobile-nav-top">
				<a href={locale === 'en' ? '/en/about' : '/a-propos'}>{t('nav.about', locale)}</a>
				<a href={locale === 'en' ? '/en/search' : '/recherche'}>{t('nav.search', locale)}</a>
				<a class="lang-switch-mobile" href={switchHref} hreflang={otherLocale}>{otherLocale.toUpperCase()}</a>
			</div>
			<span class="kicker mobile-nav-heading">{t('nav.sections', locale)}</span>
			<ul class="mobile-nav-list">
				{navLinks.map((link) => (
					<li><a href={link.href}>{link.label}</a></li>
				))}
			</ul>
		</div>
	</nav>
</header>

<script>
	function setupHeader() {
		const header = document.querySelector<HTMLElement>('.site-header');
		const trigger = document.querySelector<HTMLButtonElement>('.rubriques-trigger');
		const panel = document.querySelector<HTMLElement>('#rubriques-menu');
		const wrapper = document.querySelector<HTMLElement>('.rubriques-wrapper');
		const mobileTrigger = document.querySelector<HTMLButtonElement>('.mobile-trigger');
		const mobileMenu = document.querySelector<HTMLElement>('#mobile-menu');

		if (!header || !trigger || !panel || !wrapper || !mobileTrigger || !mobileMenu) return;
		if (header.dataset.headerReady === 'true') return;
		header.dataset.headerReady = 'true';

		let closeTimer: ReturnType<typeof setTimeout>;
		const openPanel = () => {
			clearTimeout(closeTimer);
			panel.hidden = false;
			trigger.setAttribute('aria-expanded', 'true');
		};
		const closePanel = () => {
			closeTimer = setTimeout(() => {
				panel.hidden = true;
				trigger.setAttribute('aria-expanded', 'false');
			}, 120);
		};

		wrapper.addEventListener('mouseenter', openPanel);
		wrapper.addEventListener('mouseleave', closePanel);
		panel.addEventListener('mouseenter', () => clearTimeout(closeTimer));
		panel.addEventListener('mouseleave', closePanel);
		trigger.addEventListener('click', () => {
			if (panel.hidden) openPanel(); else closePanel();
		});

		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape') {
				if (!panel.hidden) {
					panel.hidden = true;
					trigger.setAttribute('aria-expanded', 'false');
					trigger.focus();
				}
				if (!mobileMenu.hidden) closeMobile();
			}
		});

		const closeMobile = () => {
			mobileTrigger.setAttribute('aria-expanded', 'false');
			mobileMenu.hidden = true;
			document.body.classList.remove('menu-open');
			mobileTrigger.querySelector('.mobile-trigger-icon')!.innerHTML =
				`<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:block;flex:none"><path d="M4 6h16"/><path d="M4 12h16"/><path d="M4 18h16"/></svg>`;
		};

		mobileTrigger.addEventListener('click', () => {
			const expanded = mobileTrigger.getAttribute('aria-expanded') === 'true';
			if (expanded) {
				closeMobile();
			} else {
				mobileTrigger.setAttribute('aria-expanded', 'true');
				mobileMenu.hidden = false;
				document.body.classList.add('menu-open');
				mobileTrigger.querySelector('.mobile-trigger-icon')!.innerHTML =
					`<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:block;flex:none"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>`;
			}
		});

		mobileMenu.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeMobile));
		panel.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => {
			panel.hidden = true;
			trigger.setAttribute('aria-expanded', 'false');
		}));
	}

	document.addEventListener('astro:page-load', setupHeader);
	setupHeader();
</script>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 50;
		background: var(--white);
		border-bottom: 1px solid var(--border-subtle);
	}

	.header-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: var(--header-height);
		gap: var(--space-8);
	}

	.logo {
		display: inline-flex;
		align-items: center;
		color: var(--text-wordmark);
		line-height: 1;
	}

	.logo-img {
		height: clamp(1.4rem, 2.5vw, 1.9rem);
		width: auto;
		display: block;
	}

	.desktop-nav {
		display: flex;
		align-items: center;
		gap: var(--space-8);
	}

	.nav-link {
		display: inline-flex;
		align-items: center;
		gap: 0.35em;
		font-family: var(--font-body);
		font-size: var(--text-sm);
		font-weight: var(--fw-medium);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		color: var(--ink);
		padding-block: 0.4em;
		border: none;
		border-bottom: 1px solid transparent;
		background: none;
		cursor: pointer;
	}


	.nav-link:hover {
		color: var(--navy);
	}

	.rubriques-trigger[aria-expanded="true"] {
		color: var(--navy);
		border-bottom-color: var(--navy);
	}

	.chevron {
		display: flex;
		transition: transform var(--dur-fast) var(--ease-out);
	}

	.rubriques-trigger[aria-expanded="true"] .chevron {
		transform: rotate(180deg);
	}

	.search-btn {
		display: grid;
		place-items: center;
		width: 40px;
		height: 40px;
		color: var(--ink);
		border-radius: var(--radius-pill);
	}

	.search-btn:hover {
		color: var(--navy);
	}

	.lang-switch {
		display: inline-flex;
		align-items: center;
		font-family: var(--font-body);
		font-size: var(--text-xs);
		font-weight: var(--fw-semibold);
		letter-spacing: var(--tracking-wider);
		color: var(--text-muted);
		border: 1px solid var(--border-subtle);
		border-radius: var(--radius-pill);
		padding: 0.3em 0.7em;
		transition: color var(--dur-fast) var(--ease-out), border-color var(--dur-fast) var(--ease-out);
	}

	.lang-switch:hover {
		color: var(--navy);
		border-color: var(--navy);
	}

	.lang-switch-mobile {
		font-size: var(--text-sm);
		font-weight: var(--fw-semibold);
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.rubriques-panel {
		position: absolute;
		left: 0;
		right: 0;
		background: var(--white);
		border-bottom: 1px solid var(--border-subtle);
		box-shadow: var(--shadow-card);
	}

	.rubriques-panel[hidden] {
		display: none;
	}

	.rubriques-panel-inner {
		padding-block: var(--space-10);
	}

	.rubriques-panel-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		margin-bottom: var(--space-6);
		padding-bottom: var(--space-3);
		border-bottom: 1px solid var(--border-subtle);
	}

	.rubriques-panel-header .kicker {
		font-size: var(--text-xl);
		font-weight: var(--fw-bold);
	}

	.rubriques-grid {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: var(--space-3) var(--space-8);
	}

	.rubriques-grid a {
		display: block;
		font-family: var(--font-display);
		font-size: var(--text-lg);
		color: var(--text-heading);
		padding-block: var(--space-2);
	}

	.rubriques-grid a:hover {
		color: var(--navy);
	}

	.mobile-trigger {
		display: none;
		place-items: center;
		width: 44px;
		height: 44px;
		background: transparent;
		border: none;
		color: var(--ink);
		cursor: pointer;
	}

	.mobile-trigger-icon {
		display: flex;
	}

	.mobile-nav {
		border-top: 1px solid var(--border-subtle);
		background: var(--white);
	}

	.mobile-nav[hidden] {
		display: none;
	}

	.mobile-nav-inner {
		padding-block: var(--space-6);
	}

	.mobile-nav-top {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-6);
		margin-bottom: var(--space-6);
	}

	.mobile-nav-top a {
		font-weight: var(--fw-semibold);
		letter-spacing: 0.06em;
		text-transform: uppercase;
		font-size: var(--text-sm);
	}

	.mobile-nav-heading {
		display: block;
		margin-bottom: var(--space-3);
		font-size: var(--text-xl);
		font-weight: var(--fw-bold);
	}

	.mobile-nav-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
	}

	.mobile-nav-list li {
		border-top: 1px solid var(--border-subtle);
	}

	.mobile-nav-list a {
		display: block;
		font-family: var(--font-display);
		font-size: var(--text-lg);
		padding-block: var(--space-3);
	}

	@media (max-width: 900px) {
		.desktop-nav {
			display: none;
		}

		.mobile-trigger {
			display: grid;
		}

		.mobile-nav {
			position: fixed;
			inset-inline: 0;
			top: var(--header-height);
			bottom: 0;
			z-index: 45;
			height: calc(100dvh - var(--header-height));
			overflow-y: auto;
			overscroll-behavior: contain;
			-webkit-overflow-scrolling: touch;
			box-shadow: var(--shadow-lg);
		}

		.mobile-nav-inner {
			padding-block: var(--space-5) max(var(--space-8), env(safe-area-inset-bottom));
		}

		.mobile-nav-top {
			display: grid;
			grid-template-columns: repeat(3, minmax(0, 1fr));
			gap: var(--space-3);
			margin-bottom: var(--space-5);
		}

		.mobile-nav-top a {
			min-width: 0;
			border: 1px solid var(--border-subtle);
			padding: var(--space-3);
			text-align: center;
			line-height: var(--leading-snug);
		}

		.mobile-nav-list a {
			padding-block: var(--space-3);
			line-height: var(--leading-snug);
		}
	}

	@media (max-width: 460px) {
		.mobile-nav-top {
			grid-template-columns: 1fr;
		}
	}
</style>
