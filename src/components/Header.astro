---
import { CATEGORIES, slugifyCategory } from '../lib/utils';

const navLinks = CATEGORIES.map((category) => ({
	label: category,
	href: `/articles/${slugifyCategory(category)}`,
})); // TODO: categories from form
---

<header class="site-header">
	<div class="header-inner">
		<a class="logo" href="/" aria-label="Travel-Îles, accueil">
			<span class="logo-main">TRAVEL-ÎLES</span>
		</a>
		<nav class="desktop-nav" aria-label="Navigation principale">
			<div class="rubriques">
				<button
					class="nav-button"
					type="button"
					aria-expanded="false"
					aria-controls="rubriques-menu"
					aria-haspopup="true"
				>
					Rubriques
				</button>
				<div id="rubriques-menu" class="rubriques-panel" hidden>
					{navLinks.map((link) => <a href={link.href}>{link.label}</a>)}
				</div>
			</div>
			<a href="/videos">Vidéos</a>
			<a href="/a-propos">À propos</a>
			<a href="/recherche">Recherche</a>
		</nav>
		<button class="menu-toggle" type="button" aria-expanded="false" aria-controls="mobile-menu">
			<span class="sr-only">Ouvrir le menu</span>
			<span></span>
			<span></span>
			<span></span>
		</button>
	</div>
	<nav id="mobile-menu" class="mobile-nav" aria-label="Navigation mobile" hidden>
		<span class="mobile-nav-heading">Rubriques</span>
		{navLinks.map((link) => <a href={link.href}>{link.label}</a>)}
		<a href="/articles">Articles</a>
		<a href="/videos">Vidéos</a>
		<a href="/a-propos">À propos</a>
		<a href="/contact">Contact</a>
		<a href="/recherche">Recherche</a>
	</nav>
</header>

<script>
	function setupHeaderNavigation() {
		const header = document.querySelector<HTMLElement>('.site-header');
		const button = document.querySelector<HTMLButtonElement>('.menu-toggle');
		const menu = document.querySelector<HTMLElement>('#mobile-menu');
		const rubriquesButton = document.querySelector<HTMLButtonElement>('.nav-button');
		const rubriquesMenu = document.querySelector<HTMLElement>('#rubriques-menu');

		if (!header || !button || !menu) return;
		if (header.dataset.navigationReady === 'true') return;

		header.dataset.navigationReady = 'true';

		const closeMenu = () => {
			button.setAttribute('aria-expanded', 'false');
			menu.hidden = true;
			document.body.classList.remove('menu-open');
		};

		const closeRubriques = () => {
			if (!rubriquesButton || !rubriquesMenu) return;
			rubriquesButton.setAttribute('aria-expanded', 'false');
			rubriquesMenu.hidden = true;
		};

		button.addEventListener('click', () => {
			const expanded = button.getAttribute('aria-expanded') === 'true';
			button.setAttribute('aria-expanded', String(!expanded));
			menu.hidden = expanded;
			document.body.classList.toggle('menu-open', !expanded);
			closeRubriques();
		});

		menu.querySelectorAll('a').forEach((link) => {
			link.addEventListener('click', closeMenu);
		});

		if (rubriquesButton && rubriquesMenu) {
			rubriquesButton.addEventListener('click', () => {
				const expanded = rubriquesButton.getAttribute('aria-expanded') === 'true';
				rubriquesButton.setAttribute('aria-expanded', String(!expanded));
				rubriquesMenu.hidden = expanded;
				closeMenu();
			});

			rubriquesMenu.querySelectorAll('a').forEach((link) => {
				link.addEventListener('click', closeRubriques);
			});

			document.addEventListener('click', (event) => {
				if (!(event.target instanceof Node) || header.contains(event.target)) return;
				closeRubriques();
			});

			document.addEventListener('keydown', (event) => {
				if (event.key !== 'Escape') return;
				closeRubriques();
				closeMenu();
			});
		}
	}

	document.addEventListener('astro:page-load', setupHeaderNavigation);
	setupHeaderNavigation();
</script>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 20;
		background: var(--color-white);
		border-bottom: 1px solid var(--color-grey-light);
	}

	.header-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-6);
		width: min(100% - 2rem, var(--max-width));
		min-height: 4.75rem;
		margin-inline: auto;
	}

	.logo {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		color: var(--color-ink);
		white-space: nowrap;
	}

	.logo-main {
		font-family: var(--font-display);
		font-size: 1.35rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		line-height: 1;
	}

	.desktop-nav {
		display: flex;
		align-items: center;
		gap: clamp(0.8rem, 1.8vw, 1.4rem);
		color: #3f3f3f;
		font-size: 0.83rem;
		font-weight: 500;
	}

	.rubriques {
		position: relative;
	}

	.nav-button {
		border: 0;
		background: transparent;
		color: inherit;
		cursor: pointer;
		font: inherit;
		font-weight: inherit;
		padding: 0;
	}

	.nav-button:hover,
	.nav-button[aria-expanded='true'] {
		color: var(--color-navy);
	}

	.rubriques-panel {
		position: absolute;
		top: calc(100% + 1.5rem);
		right: 0;
		z-index: 30;
		display: grid;
		grid-template-columns: repeat(3, minmax(11rem, 1fr));
		gap: var(--space-3) var(--space-6);
		width: min(44rem, calc(100vw - 2rem));
		border: 1px solid var(--color-grey-light);
		background: var(--color-white);
		box-shadow: 0 1rem 2.5rem rgba(0, 0, 0, 0.08);
		padding: var(--space-6);
		color: var(--color-ink);
	}

	.rubriques-panel[hidden],
	.mobile-nav[hidden] {
		display: none;
	}

	.rubriques-panel a {
		line-height: 1.3;
	}

	.menu-toggle {
		display: none;
		width: 2.75rem;
		height: 2.75rem;
		padding: 0.65rem;
		background: transparent;
		border: 1px solid var(--color-grey-light);
		color: var(--color-ink);
		cursor: pointer;
	}

	.menu-toggle span:not(.sr-only) {
		display: block;
		height: 1px;
		margin: 0.34rem 0;
		background: currentColor;
	}

	.mobile-nav {
		border-top: 1px solid var(--color-grey-light);
		background: var(--color-white);
	}

	.mobile-nav-heading {
		display: block;
		padding: 1rem 1rem 0.5rem;
		color: var(--color-navy);
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.mobile-nav a {
		display: block;
		padding: 1rem;
		border-bottom: 1px solid var(--color-grey-light);
		font-weight: 500;
	}

	@media (max-width: 1040px) {
		.desktop-nav {
			display: none;
		}

		.menu-toggle {
			display: block;
		}
	}

	@media (max-width: 640px) {
		.header-inner {
			width: min(100% - 1.25rem, var(--max-width));
		}
	}
</style>
