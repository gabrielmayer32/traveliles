---
import { RUBRIQUES, getCategoryScope, slugifyCategory, type Category } from '../lib/utils';
import { localizedCategory, type Locale } from '../lib/i18n';

interface Props {
	active?: Category;
	locale?: Locale;
	mode?: 'links' | 'filters';
	ariaLabel?: string;
}

const {
	active,
	locale = 'fr',
	mode = 'links',
	ariaLabel = locale === 'en' ? 'Filter by section' : 'Filtrer par rubrique',
} = Astro.props;

const basePath = locale === 'en' ? '/en/articles' : '/articles';
const allLabel = locale === 'en' ? 'All' : 'Toutes';
---

<nav class="category-nav" aria-label={ariaLabel} data-category-nav>
	<div class="category-nav-primary">
		{mode === 'filters' ? (
			<button class:list={['chip', { 'chip--active': !active }]} type="button" data-categories="all">{allLabel}</button>
		) : (
			<a class="chip" href={basePath}>{allLabel}</a>
		)}

		{RUBRIQUES.map((group) => {
			const parentActive = active === group.label;
			const childActive = !!active && !!group.children?.includes(active);
			const parentClasses = ['chip', 'chip--parent', {
				'chip--active': parentActive,
				'chip--context': childActive,
			}];
			const parentLabel = localizedCategory(group.label, locale);
			const parentHref = `${basePath}/${slugifyCategory(group.label)}`;

			return mode === 'filters' ? (
				<button
					class:list={parentClasses}
					type="button"
					data-categories={getCategoryScope(group.label).join('|')}
					data-branch={group.children ? group.label : undefined}
				>
					{parentLabel}
				</button>
			) : (
				<a
					class:list={parentClasses}
					href={parentHref}
					aria-current={parentActive ? 'page' : undefined}
				>
					{parentLabel}
				</a>
			);
		})}
	</div>

	{RUBRIQUES.filter((group) => group.children).map((group) => {
		const branchActive = active === group.label || (!!active && group.children!.includes(active));
		const parentLabel = localizedCategory(group.label, locale);
		return (
			<div class="subcategory-panel" data-subcategories={group.label} hidden={!branchActive}>
				<span class="subcategory-heading">{locale === 'en' ? 'Subsections' : 'Sous-rubriques'}</span>
				<div class="subcategory-list" aria-label={`${parentLabel} — ${locale === 'en' ? 'subsections' : 'sous-rubriques'}`}>
					{group.children!.map((child) => {
						const childLabel = localizedCategory(child, locale);
						const childClasses = ['chip', 'chip--child', { 'chip--active': child === active }];
						return mode === 'filters' ? (
							<button
								class:list={childClasses}
								type="button"
								data-categories={child}
								data-parent={group.label}
							>
								{childLabel}
							</button>
						) : (
							<a
								class:list={childClasses}
								href={`${basePath}/${slugifyCategory(child)}`}
								aria-current={child === active ? 'page' : undefined}
							>
								{childLabel}
							</a>
						);
					})}
				</div>
			</div>
		);
	})}
</nav>

<script>
	function setupCategoryNav() {
		document.querySelectorAll<HTMLElement>('[data-category-nav]').forEach((nav) => {
			if (nav.dataset.ready === 'true') return;
			nav.dataset.ready = 'true';

			nav.addEventListener('click', (event) => {
				const control = (event.target as Element).closest<HTMLElement>('button.chip');
				if (!control || !nav.contains(control)) return;

				const branch = control.dataset.branch ?? control.dataset.parent ?? '';
				nav.querySelectorAll<HTMLElement>('[data-subcategories]').forEach((panel) => {
					panel.hidden = panel.dataset.subcategories !== branch;
				});

				nav.querySelectorAll<HTMLElement>('[data-branch]').forEach((parent) => {
					parent.classList.toggle('chip--context', !!control.dataset.parent && parent.dataset.branch === branch);
				});
			});
		});
	}

	document.addEventListener('astro:page-load', setupCategoryNav);
	setupCategoryNav();
</script>

<style>
	.category-nav {
		margin-bottom: var(--space-10);
	}

	.category-nav-primary {
		display: grid;
		grid-template-columns: repeat(6, minmax(0, 1fr));
		gap: var(--space-4) var(--space-6);
		padding-bottom: var(--space-5);
		border-bottom: 1px solid var(--border-subtle);
	}

	.chip {
		position: relative;
		width: max-content;
		max-width: 100%;
		appearance: none;
		font-family: var(--font-body);
		font-size: var(--text-sm);
		font-weight: var(--fw-medium);
		line-height: var(--leading-snug);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		color: var(--text-secondary);
		background: transparent;
		border: 0;
		padding: var(--space-1) 0;
		cursor: pointer;
		transition: color var(--dur-fast) var(--ease-out);
		text-decoration: none;
		text-align: left;
	}

	.chip::after {
		content: '';
		position: absolute;
		left: 0;
		right: 0;
		bottom: calc(-1 * var(--space-2));
		height: 2px;
		background: var(--navy);
		transform: scaleX(0);
		transform-origin: left;
		transition: transform var(--dur-fast) var(--ease-out);
	}

	.chip:hover,
	.chip--active,
	.chip--context {
		color: var(--navy);
	}

	.chip:hover::after,
	.chip--active::after,
	.chip--context::after {
		transform: scaleX(1);
	}

	.subcategory-panel {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr);
		align-items: center;
		gap: var(--space-6);
		margin-top: var(--space-4);
		padding: var(--space-4) var(--space-5);
		background: var(--navy-050);
		border-left: 2px solid var(--navy);
	}

	.subcategory-panel[hidden] {
		display: none;
	}

	.subcategory-heading {
		font-size: var(--text-xs);
		font-weight: var(--fw-semibold);
		letter-spacing: var(--tracking-wider);
		text-transform: uppercase;
		color: var(--navy);
	}

	.subcategory-list {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: var(--space-3) var(--space-8);
	}

	.chip--child {
		font-size: var(--text-base);
		font-weight: var(--fw-regular);
		letter-spacing: 0;
		text-transform: none;
		color: var(--text-muted);
	}

	@media (max-width: 1100px) {
		.category-nav-primary {
			grid-template-columns: repeat(4, minmax(0, 1fr));
		}
	}

	@media (max-width: 700px) {
		.category-nav-primary {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: var(--space-4);
		}

		.subcategory-panel {
			grid-template-columns: 1fr;
			gap: var(--space-3);
			padding: var(--space-4);
		}
	}
</style>
