---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../lib/utils';
import CategoryLabel from './CategoryLabel.astro';

interface Props {
	article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const href = `/articles/${article.id}`;
---

<article class="hero-article">
	<a href={href} class="hero-link" aria-label={article.data.title}>
		{article.data.cover && <img src={article.data.cover} alt="" />}
		<div class="hero-overlay">
			<CategoryLabel category={article.data.category} linked={false} />
			<h1>{article.data.title}</h1>
			<p>{article.data.excerpt}</p>
			<div class="meta">{formatDate(article.data.date)} · {article.data.author}</div>
		</div>
	</a>
</article>

<style>
	.hero-article {
		background: var(--color-ink);
	}

	.hero-link {
		position: relative;
		display: block;
		min-height: min(76vh, 48rem);
		overflow: hidden;
		color: var(--color-white);
	}

	img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0.78;
	}

	.hero-overlay {
		position: absolute;
		inset: auto 0 0;
		display: grid;
		gap: var(--space-4);
		width: min(100% - 2rem, var(--max-width));
		margin-inline: auto;
		padding-bottom: clamp(2rem, 8vw, 6rem);
	}

	h1 {
		max-width: 58rem;
		color: var(--color-white);
		font-size: clamp(3rem, 8vw, 5rem);
	}

	p {
		max-width: 42rem;
		font-size: clamp(1rem, 2vw, 1.25rem);
		line-height: 1.55;
	}

	.meta {
		color: rgba(255, 255, 255, 0.78);
	}

	:global(.hero-article .category-label) {
		color: var(--color-white);
	}

	@media (max-width: 640px) {
		.hero-link {
			min-height: 34rem;
		}

		.hero-overlay {
			width: min(100% - 1.25rem, var(--max-width));
		}
	}
</style>
