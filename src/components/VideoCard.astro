---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../lib/utils';
import CategoryLabel from './CategoryLabel.astro';
import { iconSvg } from '../lib/icons';

interface Props {
	video: CollectionEntry<'videos'>;
	size?: 'md' | 'lg';
}

const { video, size = 'md' } = Astro.props;
const href = `/videos/${video.id}`;
const { videoSource, videoId } = video.data;
const thumbnail = video.data.thumbnail ?? (
	videoSource === 'youtube'
		? `https://img.youtube.com/vi/${videoId}/hqdefault.jpg`
		: undefined
);
const playSize = size === 'lg' ? 76 : 60;
const iconSize = size === 'lg' ? 30 : 24;

const embedSrc = {
	youtube: `https://www.youtube.com/embed/${videoId}?autoplay=1&mute=0&rel=0&modestbranding=1&playsinline=1`,
	vimeo: `https://player.vimeo.com/video/${videoId}?autoplay=1&title=0&byline=0&portrait=0`,
	facebook: `https://www.facebook.com/plugins/video.php?href=${encodeURIComponent(videoId)}&autoplay=true`,
	instagram: `https://www.instagram.com/reel/${videoId}/embed/`,
}[videoSource];
---

<div class:list={['video-card', `video-card--${size}`]}>
	<div class="video-thumbnail" data-embed-src={embedSrc}>
		{thumbnail && <img src={thumbnail} alt="" loading="lazy" />}
		<span class="video-scrim"></span>
		<button
			class="play-btn"
			type="button"
			aria-label="Lancer la vidéo"
			style={`width:${playSize}px;height:${playSize}px;padding-left:${playSize * 0.06}px`}
		>
			<Fragment set:html={iconSvg('play', iconSize)} />
		</button>
	</div>
	<a class="video-body" href={href}>
		<CategoryLabel category={video.data.category} linked={false} />
		<h3 class="video-title">{video.data.title}</h3>
		<div class="meta">{formatDate(video.data.date)}</div>
	</a>
</div>

<script>
	function initVideoCards() {
		document.querySelectorAll<HTMLElement>('.video-card').forEach((card) => {
			const thumb = card.querySelector<HTMLElement>('.video-thumbnail');
			const playBtn = thumb?.querySelector<HTMLButtonElement>('.play-btn');
			if (!thumb || !playBtn || thumb.dataset.vcReady === 'true') return;
			thumb.dataset.vcReady = 'true';

			playBtn.addEventListener('click', (e) => {
				e.stopPropagation();
				const src = thumb.dataset.embedSrc;
				if (!src) return;

				const iframe = document.createElement('iframe');
				iframe.className = 'vc-iframe';
				iframe.src = src;
				iframe.title = 'Vidéo';
				iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
				iframe.allowFullscreen = true;
				thumb.appendChild(iframe);

				playBtn.hidden = true;
				const scrim = thumb.querySelector('.video-scrim');
				if (scrim) (scrim as HTMLElement).hidden = true;
			});
		});
	}
	document.addEventListener('astro:page-load', initVideoCards);
	initVideoCards();
</script>

<style>
	.video-card {
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
		color: inherit;
	}

	.video-thumbnail {
		position: relative;
		overflow: hidden;
		aspect-ratio: 16 / 9;
		background: var(--navy-950);
		border-radius: var(--radius-xs);
	}

	.video-thumbnail img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0.82;
		transform: scale(1);
		transition: all var(--dur-slow) var(--ease-out);
	}

	.video-card:hover .video-thumbnail img {
		opacity: 0.9;
		transform: scale(1.04);
	}

	.video-scrim {
		position: absolute;
		inset: 0;
		background: linear-gradient(to top, rgba(20, 26, 63, 0.45), rgba(20, 26, 63, 0) 60%);
		pointer-events: none;
	}

	.play-btn {
		position: absolute;
		inset: 0;
		margin: auto;
		display: grid;
		place-items: center;
		border-radius: var(--radius-pill);
		background: rgba(255, 255, 255, 0.92);
		color: var(--navy);
		border: 1px solid rgba(255, 255, 255, 0.6);
		box-shadow: 0 6px 24px rgba(20, 26, 63, 0.28);
		transition: all var(--dur) var(--ease-out);
		cursor: pointer;
		z-index: 2;
	}

	.play-btn:hover {
		background: var(--navy);
		color: var(--white);
	}

	.play-btn[hidden] {
		display: none;
	}

	.video-thumbnail :global(.vc-iframe) {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		border: 0;
		z-index: 3;
	}

	.video-body {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
		color: inherit;
	}

	.video-title {
		font-size: var(--text-lg);
		line-height: var(--leading-snug);
		color: var(--text-heading);
		transition: color var(--dur-fast) var(--ease-out);
	}

	.video-card--lg .video-title {
		font-size: var(--text-xl);
	}

	.video-card:hover .video-title {
		color: var(--navy);
	}
</style>
