---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../lib/utils';
import CategoryLabel from './CategoryLabel.astro';

interface Props {
	video: CollectionEntry<'videos'>;
}

const { video } = Astro.props;
const href = `/videos/${video.id}`;
const thumbnail = video.data.thumbnail ?? (
	video.data.videoSource === 'youtube'
		? `https://img.youtube.com/vi/${video.data.videoId}/hqdefault.jpg`
		: undefined
);
---

<article class="video-card">
	<a class="video-image" href={href} aria-label={video.data.title}>
		{thumbnail && <img src={thumbnail} alt="" loading="lazy" />}
		<span class="play-icon" aria-hidden="true"></span>
	</a>
	<div class="video-body">
		<CategoryLabel category={video.data.category} />
		<h3><a href={href}>{video.data.title}</a></h3>
		<div class="meta">{formatDate(video.data.date)}</div>
	</div>
</article>

<style>
	.video-card {
		display: grid;
		gap: var(--space-4);
	}

	.video-image {
		position: relative;
		display: block;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		background: var(--color-grey-light);
	}

	.video-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.play-icon {
		position: absolute;
		left: 50%;
		top: 50%;
		width: 3rem;
		height: 3rem;
		border: 1px solid var(--color-white);
		transform: translate(-50%, -50%);
	}

	.play-icon::after {
		content: '';
		position: absolute;
		left: 1.18rem;
		top: 0.82rem;
		border-block: 0.68rem solid transparent;
		border-left: 1rem solid var(--color-white);
	}

	.video-body {
		display: grid;
		gap: var(--space-3);
	}

	h3 {
		font-size: clamp(1.05rem, 1.6vw, 1.35rem);
		line-height: 1.18;
	}
</style>
