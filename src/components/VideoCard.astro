---
import type { CollectionEntry } from 'astro:content';
import { formatDateLocale, type Locale } from '../lib/i18n';
import CategoryLabel from './CategoryLabel.astro';
import { iconSvg } from '../lib/icons';

interface Props {
	video: CollectionEntry<'videos'>;
	size?: 'md' | 'lg';
	locale?: Locale;
}

const { video, size = 'md', locale = 'fr' } = Astro.props;
const href = locale === 'en' ? `/en/videos/${video.id}` : `/videos/${video.id}`;
const thumbnail = video.data.thumbnail ?? (
	video.data.videoSource === 'youtube'
		? `https://img.youtube.com/vi/${video.data.videoId}/hqdefault.jpg`
		: undefined
);
const playSize = size === 'lg' ? 76 : 60;
const iconSize = Math.round(playSize * 0.4);
const playPaddingLeft = Math.round(playSize * 0.06);
const duration = (video.data as any).duration as string | undefined;
---

<a class:list={['video-card', `video-card--${size}`]} href={href}>
	<div class="video-thumbnail">
		{thumbnail && <img src={thumbnail} alt="" loading="lazy" />}
		<span class="video-scrim"></span>
		<span class="play-btn" style={`width:${playSize}px;height:${playSize}px;padding-left:${playPaddingLeft}px`}>
			<Fragment set:html={iconSvg('play', iconSize)} />
		</span>
		{duration && (
			<span class="video-duration">{duration}</span>
		)}
	</div>
	<div class="video-body">
		<CategoryLabel category={video.data.category} linked={false} />
		<h3 class="video-title">{video.data.title}</h3>
		<div class="meta">{formatDateLocale(video.data.date, locale)}</div>
	</div>
</a>

<style>
	.video-card {
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
		color: inherit;
	}

	.video-thumbnail {
		position: relative;
		overflow: hidden;
		aspect-ratio: 16 / 9;
		background: var(--navy-950);
		border-radius: var(--radius-xs);
	}

	.video-thumbnail img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0.82;
		transform: scale(1);
		transition: all var(--dur-slow) var(--ease-out);
	}

	.video-card:hover .video-thumbnail img {
		opacity: 0.9;
		transform: scale(1.04);
	}

	.video-scrim {
		position: absolute;
		inset: 0;
		background: linear-gradient(to top, rgba(20, 26, 63, 0.45), rgba(20, 26, 63, 0) 60%);
	}

	.play-btn {
		position: absolute;
		inset: 0;
		margin: auto;
		display: grid;
		place-items: center;
		border-radius: var(--radius-pill);
		background: rgba(255, 255, 255, 0.92);
		color: var(--navy);
		box-shadow: 0 6px 24px rgba(20, 26, 63, 0.28);
		transition: all var(--dur) var(--ease-out);
	}

	.video-card:hover .play-btn {
		background: var(--navy);
		color: var(--white);
	}

	.video-duration {
		position: absolute;
		right: var(--space-3);
		bottom: var(--space-3);
		padding: 0.2em 0.55em;
		background: rgba(20, 26, 63, 0.78);
		color: var(--white);
		font-family: var(--font-body);
		font-size: var(--text-xs);
		font-weight: var(--fw-medium);
		letter-spacing: 0.02em;
		border-radius: var(--radius-xs);
	}

	.video-body {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}

	.video-title {
		font-size: var(--text-lg);
		line-height: var(--leading-snug);
		color: var(--text-heading);
		transition: color var(--dur-fast) var(--ease-out);
		margin: 0;
	}

	.video-card--lg .video-title {
		font-size: var(--text-xl);
	}

	.video-card:hover .video-title {
		color: var(--navy);
	}
</style>
