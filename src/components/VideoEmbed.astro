---
interface Props {
	videoSource: 'youtube' | 'vimeo';
	videoId: string;
	title?: string;
}

const { videoSource, videoId, title = 'Vidéo Côte Nord' } = Astro.props;
const src = videoSource === 'youtube'
	? `https://www.youtube.com/embed/${videoId}`
	: `https://player.vimeo.com/video/${videoId}`;
---

<div class="video-embed">
	<iframe
		src={src}
		title={title}
		loading="lazy"
		allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
		allowfullscreen
	></iframe>
</div>

<style>
	.video-embed {
		aspect-ratio: 16 / 9;
		width: 100%;
		background: var(--color-ink);
	}

	iframe {
		display: block;
		width: 100%;
		height: 100%;
		border: 0;
	}
</style>
