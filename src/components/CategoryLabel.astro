---
import { slugifyCategory } from '../lib/utils';
import { localizedCategory, type Locale } from '../lib/i18n';

interface Props {
	category: string;
	variant?: 'plain' | 'solid' | 'outline' | 'overlay';
	linked?: boolean;
	locale?: Locale;
}

const { category, variant = 'plain', linked = true, locale = 'fr' } = Astro.props;
const href = locale === 'en'
	? `/en/articles/${slugifyCategory(category)}`
	: `/articles/${slugifyCategory(category)}`;
const label = localizedCategory(category, locale);
---

{
	linked ? (
		<a class:list={['category-label', `category-label--${variant}`]} href={href}>{label}</a>
	) : (
		<span class:list={['category-label', `category-label--${variant}`]}>{label}</span>
	)
}

<style>
	.category-label {
		display: inline-block;
		font-family: var(--font-body);
		font-size: var(--text-xs);
		font-weight: var(--fw-semibold);
		letter-spacing: var(--tracking-wider);
		text-transform: uppercase;
		line-height: 1.1;
		white-space: nowrap;
	}

	.category-label--plain {
		color: var(--navy);
	}

	.category-label--solid {
		color: var(--white);
		background: var(--navy);
		padding: 0.4em 0.7em;
	}

	.category-label--outline {
		color: var(--navy);
		border: 1px solid var(--navy);
		padding: 0.4em 0.7em;
	}

	.category-label--overlay {
		color: var(--white);
		background: rgba(20, 26, 63, 0.55);
		backdrop-filter: blur(4px);
		padding: 0.4em 0.7em;
	}
</style>
